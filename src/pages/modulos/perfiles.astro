---
// src/pages/modulos/perfiles.astro
import Layout from '../../layout/layout.astro';
import ModalForm from '../../components/ModalForm.astro';

const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Gestión de Perfiles";
---

<Layout title={`${pageTitle} | Sistema Corporativo`} moduloActual="Perfil">
  <div class="page-header">
    <h1><i class="fas fa-user-shield"></i> {pageTitle}</h1>
    <div id="header-actions"></div> 
  </div>

  <div id="modalFormContainer" style="display:none;">
    <ModalForm title="Perfil" id="modalForm">
      <form id="perfilForm" slot="form" class="modal-form">
        <input type="hidden" id="perfilId">
        <div class="form-group">
          <label for="strNombrePerfil">Nombre del Perfil *</label>
          <input type="text" id="strNombrePerfil" required maxlength="100" />
        </div>

        <div class="form-group checkbox-group">
          <label>
            <input type="checkbox" id="bitAdministrador" />
            ¿Es Administrador? (Acceso total)
          </label>
        </div>

        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="window.closeModal()">Cancelar</button>
          <button type="submit" class="btn-primary" id="btnGuardar">Guardar</button>
        </div>
      </form>
    </ModalForm>
  </div>

  <div id="loading" style="display: none; text-align: center; padding: 2rem;">
    <i class="fas fa-spinner fa-spin fa-2x"></i>
  </div>

  <div id="tableContainer" class="table-responsive">
    </div>

  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script>
  // RUTA CORREGIDA: Doble punto para subir desde /modulos/ a /src/
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";
  
  let currentPage = 1;
  const { permisos } = verificarPermisosModulo('Perfil');

  const messageDiv = document.getElementById('message');
  const perfilForm = document.getElementById('perfilForm') as HTMLFormElement;

  async function cargarDatos(page = 1) {
    if (!permisos.consulta) return;
    currentPage = page;
    
    const loading = document.getElementById('loading');
    if(loading) loading.style.display = 'block';

    try {
      const token = localStorage.getItem('token');
      const res = await fetch(`${API_URL}/api/perfiles?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await res.json();

      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      showMsg('Error al conectar con el servidor', 'error');
    } finally {
      if(loading) loading.style.display = 'none';
    }
  }

  function renderizarTabla(perfiles) {
    const container = document.getElementById('tableContainer');
    if(!container) return;

    container.innerHTML = `
      <table class="crud-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Perfil</th>
            <th>Admin</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          ${perfiles.map(p => `
            <tr>
              <td>${p.id}</td>
              <td><strong>${p.strnombreperfil}</strong></td>
              <td>${p.bitadministrador ? '✅' : '❌'}</td>
              <td class="actions-cell">
                ${permisos.editar ? `<button onclick="window.prepararEdicion(${p.id}, '${p.strnombreperfil}', ${p.bitadministrador})" class="btn-icon edit" title="Editar"><i class="fas fa-edit"></i></button>` : ''}
                ${permisos.eliminar ? `<button onclick="window.eliminarPerfil(${p.id})" class="btn-icon delete" title="Eliminar"><i class="fas fa-trash"></i></button>` : ''}
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  function renderizarPaginacion(pagination) {
    const div = document.getElementById('pagination');
    if (!div) return;
    if (pagination.totalPages <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="window.cargarDatos(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  // Hacer funciones globales para botones inyectados y eventos onclick
  window.cargarDatos = cargarDatos;
  
  window.closeModal = () => {
    const modal = document.getElementById('modalFormContainer');
    if(modal) modal.style.display = 'none';
    if(perfilForm) perfilForm.reset();
  };

  window.agregarNuevo = () => {
    (document.getElementById('perfilId') as HTMLInputElement).value = '';
    document.getElementById('btnGuardar').textContent = 'Guardar';
    const modal = document.getElementById('modalFormContainer');
    if(modal) modal.style.display = 'flex';
  };

  window.prepararEdicion = (id, nombre, isAdmin) => {
    (document.getElementById('perfilId') as HTMLInputElement).value = id;
    (document.getElementById('strNombrePerfil') as HTMLInputElement).value = nombre;
    (document.getElementById('bitAdministrador') as HTMLInputElement).checked = isAdmin;
    document.getElementById('btnGuardar').textContent = 'Actualizar';
    const modal = document.getElementById('modalFormContainer');
    if(modal) modal.style.display = 'flex';
  };

  perfilForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('perfilId') as HTMLInputElement).value;
    const body = {
      strNombrePerfil: (document.getElementById('strNombrePerfil') as HTMLInputElement).value.trim(),
      bitAdministrador: (document.getElementById('bitAdministrador') as HTMLInputElement).checked
    };

    const token = localStorage.getItem('token');
    const method = id ? 'PUT' : 'POST';
    const url = id ? `${API_URL}/api/perfiles/${id}` : `${API_URL}/api/perfiles`;

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(body)
    });

    const data = await res.json();
    if (data.success) {
      showMsg(id ? 'Actualizado correctamente' : 'Creado correctamente', 'success');
      window.closeModal();
      cargarDatos(currentPage);
    } else {
      showMsg(data.message, 'error');
    }
  });

  window.eliminarPerfil = async (id) => {
    if (!confirm('¿Desea eliminar este perfil?')) return;
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/perfiles/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    if ((await res.json()).success) {
      showMsg('Eliminado', 'success');
      cargarDatos(currentPage);
    }
  };

  function showMsg(text, type) {
    if(!messageDiv) return;
    messageDiv.style.display = 'block';
    messageDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
    messageDiv.textContent = text;
    setTimeout(() => { if(messageDiv) messageDiv.style.display = 'none'; }, 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) {
      const btn = document.createElement('button');
      btn.className = 'btn-add-global';
      btn.innerHTML = '<i class="fas fa-plus"></i> Nuevo Perfil';
      btn.onclick = window.agregarNuevo;
      document.getElementById('header-actions')?.appendChild(btn);
    }
    cargarDatos();
  });
</script>

<style>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-add-global { background: #059669; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
  #modalFormContainer { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 3000; display: flex; align-items: center; justify-content: center; }
  .modal-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group input[type="text"] { padding: 0.7rem; border: 1px solid #ddd; border-radius: 4px; }
  .checkbox-group label { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem; }
  .form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 1rem; }
  .crud-table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; }
  .crud-table th, .crud-table td { padding: 1rem; border-bottom: 1px solid #e2e8f0; text-align: left; }
  .crud-table th { background: #f8fafc; color: #475569; font-weight: 600; font-size: 0.85rem; }
  .actions-cell { display: flex; gap: 8px; }
  .btn-icon { border: none; background: none; cursor: pointer; padding: 0.5rem; transition: transform 0.2s; }
  .btn-icon:hover { transform: scale(1.1); }
  .edit { color: #f59e0b; }
  .delete { color: #ef4444; }
  .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 1.5rem; }
  .pagination button { padding: 5px 12px; border: 1px solid #ddd; background: white; cursor: pointer; border-radius: 4px; }
  .pagination button.active { background: #1e293b; color: white; border-color: #1e293b; }
  .status-message { position: fixed; bottom: 2rem; right: 2rem; padding: 1rem 2rem; border-radius: 6px; display: none; z-index: 4000; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
</style>