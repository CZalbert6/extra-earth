---
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Gestión de Usuarios" moduloActual="Usuario">
  <div class="page-header">
    <h1><i class="fas fa-users"></i> Gestión de Usuarios</h1>
    <button class="btn-add" id="btnNuevoUsuario" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Usuario
    </button>
  </div>

  <div id="modalUsuario" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Usuario</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="usuarioForm" onsubmit="event.preventDefault(); guardarUsuario();">
        <input type="hidden" id="usuarioId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Usuario *</label>
            <input type="text" id="username" required maxlength="100">
          </div>
          
          <div class="form-group">
            <label>Nombre Completo *</label>
            <input type="text" id="nombre" required>
          </div>

          <div class="form-group">
            <label>Correo *</label>
            <input type="email" id="email" required>
          </div>
          
          <div class="form-group">
            <label>Teléfono</label>
            <input type="text" id="strNumeroCelular">
          </div>
          
          <div class="form-group">
            <label>Perfil</label>
            <select id="idPerfil">
              <option value="">Seleccione...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Estado</label>
            <select id="idEstadoUsuario">
              <option value="1">Activo</option>
              <option value="0">Inactivo</option>
            </select>
          </div>
          
          <div class="form-group" style="grid-column: span 2;">
            <label>Contraseña</label>
            <input type="password" id="password" minlength="6">
            <small>Mínimo 6 caracteres. Dejar vacío para no cambiar en edición.</small>
          </div>
        </div>
        
        <div class="form-group imagen-group">
          <label>Foto de Perfil</label>
          <div class="imagen-preview" id="imagenPreview">
            <img id="previewImg" src="#" alt="Vista previa" style="display: none;">
            <div class="preview-placeholder" id="previewPlaceholder">
              <i class="fas fa-user"></i>
            </div>
          </div>
          
          <div class="imagen-input">
            <input type="file" id="imagenFile" accept="image/jpeg,image/png,image/gif" onchange="previsualizarImagen(event)">
            <button type="button" class="btn-clear" onclick="limpiarImagen()" style="display: none;" id="btnClearImagen">
              <i class="fas fa-times"></i> Quitar imagen
            </button>
          </div>
          <input type="hidden" id="strImagenBase64">
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar Usuario</button>
        </div>
      </form>
    </div>
  </div>

  <div id="loading" style="display: none; text-align: center; padding: 2rem;">
    <i class="fas fa-spinner fa-spin fa-2x"></i><br>Cargando usuarios...
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaUsuarios">
      <thead>
        <tr>
          <th>ID</th>
          <th>Foto</th>
          <th>Usuario</th>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Perfil</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="8" class="no-data">Cargando...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  let currentPage = 1;
  let currentItem = null;
  
  // 1. OBTENER PERMISOS PARA ESTE MÓDULO (Requisito PDF)
  const { permisos, tieneAcceso } = verificarPermisosModulo('Usuario');

  window.previsualizarImagen = (event) => {
    const file = event.target.files[0];
    if (file) {
      if (file.size > 2 * 1024 * 1024) { // Límite 2MB para Base64
        alert('La imagen es muy pesada. Máximo 2MB.');
        return;
      }
      const reader = new FileReader();
      reader.onload = (e) => {
        const base64 = e.target.result;
        document.getElementById('strImagenBase64').value = base64;
        document.getElementById('previewImg').src = base64;
        document.getElementById('previewImg').style.display = 'block';
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      };
      reader.readAsDataURL(file);
    }
  };

  window.limpiarImagen = () => {
    document.getElementById('imagenFile').value = '';
    document.getElementById('strImagenBase64').value = '';
    document.getElementById('previewImg').style.display = 'none';
    document.getElementById('previewPlaceholder').style.display = 'flex';
    document.getElementById('btnClearImagen').style.display = 'none';
  };

  async function cargarPerfiles() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/perfiles-lista`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      const select = document.getElementById('idPerfil');
      select.innerHTML = '<option value="">Seleccione...</option>' + 
        data.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
    }
  }

  async function cargarUsuarios(page = 1) {
    if (!permisos.consulta) return; // Si no tiene permiso de consulta, no hace nada
    
    document.getElementById('loading').style.display = 'block';
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      console.error(error);
    } finally {
      document.getElementById('loading').style.display = 'none';
    }
  }

  function renderizarTabla(usuarios) {
    const tbody = document.getElementById('tablaBody');
    tbody.innerHTML = usuarios.map(u => `
      <tr>
        <td>${u.id}</td>
        <td>
          <img src="${u.strimagen || 'https://ui-avatars.com/api/?name=' + u.username}" class="foto-perfil-tabla">
        </td>
        <td>${u.username}</td>
        <td>${u.nombre}</td>
        <td>${u.email}</td>
        <td>${u.strnombreperfil || 'Sin perfil'}</td>
        <td>
          <span class="badge ${u.idestadousuario === 1 ? 'badge-active' : 'badge-inactive'}">
            ${u.idestadousuario === 1 ? 'Activo' : 'Inactivo'}
          </span>
        </td>
        <td class="actions-cell">
          ${permisos.detalle ? `<button class="btn-icon view" onclick="verDetalle(${u.id})"><i class="fas fa-eye"></i></button>` : ''}
          ${permisos.editar ? `<button class="btn-icon edit" onclick="editarUsuario(${u.id})"><i class="fas fa-edit"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="btn-icon delete" onclick="eliminarUsuario(${u.id})"><i class="fas fa-trash"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Nuevo Usuario';
    document.getElementById('usuarioForm').reset();
    document.getElementById('usuarioId').value = '';
    document.getElementById('password').required = true;
    limpiarImagen();
    document.getElementById('modalUsuario').style.display = 'flex';
  };

  window.cerrarModal = () => {
    document.getElementById('modalUsuario').style.display = 'none';
  };

  window.editarUsuario = async (id) => {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      const u = data.data;
      document.getElementById('modalTitulo').textContent = 'Editar Usuario';
      document.getElementById('usuarioId').value = u.id;
      document.getElementById('username').value = u.username;
      document.getElementById('nombre').value = u.nombre;
      document.getElementById('email').value = u.email;
      document.getElementById('strNumeroCelular').value = u.strnumerocelular || '';
      document.getElementById('idPerfil').value = u.idperfil || '';
      document.getElementById('idEstadoUsuario').value = u.idestadousuario;
      document.getElementById('password').required = false;
      
      if (u.strimagen) {
        document.getElementById('strImagenBase64').value = u.strimagen;
        document.getElementById('previewImg').src = u.strimagen;
        document.getElementById('previewImg').style.display = 'block';
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      }
      document.getElementById('modalUsuario').style.display = 'flex';
    }
  };

  window.guardarUsuario = async () => {
    const id = document.getElementById('usuarioId').value;
    const body = {
      username: document.getElementById('username').value,
      nombre: document.getElementById('nombre').value,
      email: document.getElementById('email').value,
      password: document.getElementById('password').value,
      idPerfil: document.getElementById('idPerfil').value,
      idEstadoUsuario: document.getElementById('idEstadoUsuario').value,
      strNumeroCelular: document.getElementById('strNumeroCelular').value,
      strImagenBase64: document.getElementById('strImagenBase64').value
    };

    const token = localStorage.getItem('token');
    const response = await fetch(id ? `${API_URL}/api/usuarios/${id}` : `${API_URL}/api/usuarios`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(body)
    });

    if ((await response.json()).success) {
      cerrarModal();
      cargarUsuarios(currentPage);
    }
  };

  window.eliminarUsuario = async (id) => {
    if (!confirm('¿Eliminar usuario?')) return;
    const token = localStorage.getItem('token');
    await fetch(`${API_URL}/api/usuarios/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    cargarUsuarios(currentPage);
  };

  // INICIALIZACIÓN
  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) document.getElementById('btnNuevoUsuario').style.display = 'block';
    cargarPerfiles();
    cargarUsuarios();
  });
</script>

<style>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-add { background: #059669; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; }
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
  .modal-content { background: white; padding: 2rem; border-radius: 8px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; margin-bottom: 1rem; }
  .form-group label { font-weight: 600; margin-bottom: 0.5rem; }
  .form-group input, .form-group select { padding: 0.6rem; border: 1px solid #ddd; border-radius: 4px; }
  .imagen-preview { width: 80px; height: 80px; border-radius: 50%; overflow: hidden; background: #eee; margin-bottom: 1rem; }
  .imagen-preview img { width: 100%; height: 100%; object-fit: cover; }
  .crud-table { width: 100%; border-collapse: collapse; background: white; }
  .crud-table th, .crud-table td { padding: 1rem; border-bottom: 1px solid #eee; text-align: left; }
  .foto-perfil-tabla { width: 35px; height: 35px; border-radius: 50%; object-fit: cover; }
  .badge { padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; }
  .badge-active { background: #dcfce7; color: #166534; }
  .badge-inactive { background: #fee2e2; color: #991b1b; }
  .btn-icon { border: none; background: none; cursor: pointer; margin-right: 0.5rem; }
  .btn-icon.edit { color: #f59e0b; }
  .btn-icon.delete { color: #ef4444; }
  .btn-icon.view { color: #3b82f6; }
</style>