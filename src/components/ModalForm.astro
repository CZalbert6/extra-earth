---
// src/components/ModalForm.astro
interface Props {
  title: string;
  id: string; // Añadimos ID obligatorio para controlarlo por JS
  size?: 'small' | 'medium' | 'large';
}

const { title, id, size = 'medium' } = Astro.props;
const sizeClass = `modal-${size}`;
---

<div class="modal-overlay" id={id} style="display: none;">
  <div class={`modal-container ${sizeClass}`}>
    <div class="modal-header">
      <h3>{title}</h3>
      <button class="close-btn" type="button" onclick={`document.getElementById('${id}').style.display='none'`}>
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <slot name="form" />
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000; /* Aumentamos el z-index para que esté por encima de todo */
    padding: 1rem;
    backdrop-filter: blur(2px); /* Un toque de estilo extra */
  }

  .modal-container {
    background: white;
    border-radius: 8px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    animation: slideIn 0.3s ease-out;
  }

  .modal-small { width: 400px; }
  .modal-medium { width: 600px; }
  .modal-large { width: 800px; }

  .modal-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    background: white;
    z-index: 10;
  }

  .modal-header h3 {
    margin: 0;
    color: #1e293b;
    font-size: 1.25rem;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    color: #64748b;
    padding: 0.5rem;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .close-btn:hover {
    background: #f1f5f9;
    color: #ef4444; /* Rojo al pasar el mouse */
  }

  .modal-body {
    padding: 1.5rem;
  }

  @keyframes slideIn {
    from { transform: translateY(-30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 768px) {
    .modal-small, .modal-medium, .modal-large {
      width: 95%;
      margin: 0 auto;
    }
  }
</style>