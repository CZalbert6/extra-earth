---
// src/pages/modulos/permisos.astro
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Matriz de Permisos por Perfil";
---

<Layout title={`${pageTitle} | Sistema Corporativo`} moduloActual="Permisos-Perfil">
  <div class="page-header">
    <div class="header-title">
      <h1><i class="fas fa-shield-alt"></i> {pageTitle}</h1>
      <p>Selecciona un perfil para gestionar sus accesos globales</p>
    </div>
    
    <div class="form-group" style="min-width: 300px; margin: 0;">
      <div class="select-wrapper">
        <select id="selectPerfilMaster" onchange="cargarMatrizDePerfil(this.value)">
          <option value="">-- Seleccionar Perfil para Editar --</option>
        </select>
        <i class="fas fa-chevron-down select-icon"></i>
      </div>
    </div>
  </div>

  <div id="estadoVacio" class="empty-state">
      <i class="fas fa-user-shield"></i>
      <h2>Selecciona un perfil</h2>
      <p>Elige un perfil en la parte superior para cargar su matriz de permisos.</p>
  </div>

  <div class="card-container" id="contenedorPrincipal" style="display: none;">
    <div class="table-toolbar">
      <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar módulo en la matriz...">
      </div>
    </div>

    <div class="table-responsive">
      <table class="crud-table" id="tablaPermisos">
        <thead>
          <tr>
            <th>Módulo</th>
            <th class="text-center">Consultar</th> 
            <th class="text-center">Agregar</th> 
            <th class="text-center">Editar</th> 
            <th class="text-center">Detalle</th> 
            <th class="text-center">Eliminar</th> 
          </tr>
        </thead>
        <tbody id="tablaBody">
        </tbody>
      </table>
    </div>
    
    <div id="paginationInfo" style="margin-top: 15px; font-size: 0.85rem; color: #64748b;"></div>
    <div id="pagination" class="pagination"></div>

    <div class="form-actions" style="margin-top: 20px; border-top: 1px solid #e2e8f0; padding-top: 20px; justify-content: flex-end;">
        <button class="btn-primary" id="btnGuardarMatriz" onclick="guardarMatrizCompleta()">
            <i class="fas fa-save"></i> Guardar Matriz de Permisos
        </button>
    </div>
  </div>

  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";
  const { permisos } = verificarPermisosModulo('Permisos-Perfil');

  let todosLosModulos = [];
  let modulosFiltrados = [];
  let paginaActual = 1;
  const limitePorPagina = 5; 
  
  // EL CEREBRO: Aquí guardaremos los cambios en memoria mientras navega
  let matrizBorrador = {};

  // --- 1. CARGA INICIAL ---
  async function inicializarVista() {
    try {
      const token = localStorage.getItem('token');
      const [modulosRes, perfilesRes] = await Promise.all([
        fetch(`${API_URL}/api/modulos-lista`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API_URL}/api/perfiles-lista`, { headers: { 'Authorization': `Bearer ${token}` } })
      ]);
      
      const modData = await modulosRes.json();
      const perfData = await perfilesRes.json();
      
      if (modData.success) todosLosModulos = modData.data;
      
      if (perfData.success) {
        const select = document.getElementById('selectPerfilMaster');
        select.innerHTML = '<option value="">-- Seleccionar Perfil para Editar --</option>' + 
          perfData.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
      }
    } catch (error) { console.error('Error inicial:', error); }
  }

  // --- 2. RECOLECTAR Y CREAR EL BORRADOR EN MEMORIA ---
  window.cargarMatrizDePerfil = async (idPerfil) => {
    const contenedor = document.getElementById('contenedorPrincipal');
    const estadoVacio = document.getElementById('estadoVacio');

    if (!idPerfil) {
        contenedor.style.display = 'none';
        estadoVacio.style.display = 'block';
        return;
    }

    estadoVacio.style.display = 'none';
    contenedor.style.display = 'block';
    document.getElementById('tablaBody').innerHTML = '<tr><td colspan="6" class="no-data"><i class="fas fa-spinner fa-spin" style="font-size:2rem; margin-bottom:10px;"></i><br>Cargando configuración...</td></tr>';

    try {
      const token = localStorage.getItem('token');
      let todosLosPermisosDB = [];

      let res = await fetch(`${API_URL}/api/permisos-perfil?page=1`, { headers: { 'Authorization': `Bearer ${token}` } });
      let data = await res.json();
      
      if (data.success) {
        todosLosPermisosDB = [...data.data];
        let totalPages = data.pagination.totalPages;

        if (totalPages > 1) {
          let promesas = [];
          for (let i = 2; i <= totalPages; i++) {
            promesas.push(fetch(`${API_URL}/api/permisos-perfil?page=${i}`, { headers: { 'Authorization': `Bearer ${token}` } }).then(r => r.json()));
          }
          let extras = await Promise.all(promesas);
          extras.forEach(p => { if (p.success) todosLosPermisosDB.push(...p.data); });
        }
      }
      
      const permisosDelPerfil = todosLosPermisosDB.filter(p => p.idperfil == idPerfil);
      
      // INICIALIZAMOS EL BORRADOR (La Memoria)
      matrizBorrador = {};
      todosLosModulos.forEach(modulo => {
         const permisoDB = permisosDelPerfil.find(p => p.idmodulo == modulo.id);
         matrizBorrador[modulo.id] = {
             idPermiso: permisoDB ? permisoDB.id : null,
             c: permisoDB ? permisoDB.bitconsulta : false,
             a: permisoDB ? permisoDB.bitagregar : false,
             e: permisoDB ? permisoDB.biteditar : false,
             d: permisoDB ? permisoDB.bitdetalle : false,
             x: permisoDB ? permisoDB.biteliminar : false,
             modificado: false // Bandera para saber si el usuario lo tocó
         };
      });

      modulosFiltrados = [...todosLosModulos];
      paginaActual = 1;
      dibujarMatriz();
      
    } catch (error) {
      mostrarMensaje("Error al conectar con la base de datos", "error");
    }
  };

  // --- 3. DIBUJAR LA TABLA LEYENDO LA MEMORIA (EL BORRADOR) ---
  function dibujarMatriz() {
    const start = (paginaActual - 1) * limitePorPagina;
    const modulosPaginados = modulosFiltrados.slice(start, start + limitePorPagina);
    const tbody = document.getElementById('tablaBody');

    if (modulosPaginados.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="no-data">No se encontraron módulos.</td></tr>';
      document.getElementById('paginationInfo').textContent = '';
      document.getElementById('pagination').innerHTML = '';
      return;
    }

    tbody.innerHTML = modulosPaginados.map(modulo => {
      // Leemos el estado desde nuestro borrador en memoria
      const estado = matrizBorrador[modulo.id];
      
      // Si todos están activos, el check maestro también
      const todosActivos = estado.c && estado.a && estado.e && estado.d && estado.x;

      const crearCheck = (campo, valor) => `
        <label class="permiso-item">
          <input type="checkbox" onchange="actualizarMemoria(${modulo.id}, '${campo}', this.checked)" ${valor ? 'checked' : ''}> 
          <span class="checkmark"></span> 
        </label>
      `;

      return `
        <tr>
          <td style="vertical-align: middle; font-weight: 500; color: #334155;">
            <label style="display:flex; align-items:center; gap:10px; cursor:pointer; margin:0;">
              <input type="checkbox" class="mod-row-check" style="accent-color: #1e3a8a; width: 16px; height: 16px;" onchange="activarTodaFila(${modulo.id}, this.checked)" ${todosActivos ? 'checked' : ''}>
              ${modulo.strnombremodulo}
            </label>
          </td>
          <td class="text-center">${crearCheck('c', estado.c)}</td>
          <td class="text-center">${crearCheck('a', estado.a)}</td>
          <td class="text-center">${crearCheck('e', estado.e)}</td>
          <td class="text-center">${crearCheck('d', estado.d)}</td>
          <td class="text-center">${crearCheck('x', estado.x)}</td>
        </tr>
      `;
    }).join('');

    const totalItems = modulosFiltrados.length;
    const end = Math.min(start + limitePorPagina, totalItems);
    document.getElementById('paginationInfo').textContent = `Mostrando ${start + 1} a ${end} de ${totalItems} módulos`;

    renderizarPaginacionHTML(Math.ceil(totalItems / limitePorPagina));
  }

  // --- FUNCIONES PARA ACTUALIZAR LA MEMORIA (Sin guardar en BD todavía) ---
  window.actualizarMemoria = (idModulo, campo, valor) => {
      matrizBorrador[idModulo][campo] = valor;
      matrizBorrador[idModulo].modificado = true; // Marcamos que hubo un cambio
      
      // Verificamos si hay que marcar/desmarcar el check maestro de la fila
      const e = matrizBorrador[idModulo];
      const checkMaestro = document.querySelector(`tr[data-idmodulo="${idModulo}"] .mod-row-check`);
      if(checkMaestro) {
          checkMaestro.checked = (e.c && e.a && e.e && e.d && e.x);
      }
  };

  window.activarTodaFila = (idModulo, valor) => {
      matrizBorrador[idModulo].c = valor;
      matrizBorrador[idModulo].a = valor;
      matrizBorrador[idModulo].e = valor;
      matrizBorrador[idModulo].d = valor;
      matrizBorrador[idModulo].x = valor;
      matrizBorrador[idModulo].modificado = true;
      dibujarMatriz(); // Redibujamos para que se vean las palomitas puestas
  };

  // --- PAGINACIÓN ---
  function renderizarPaginacionHTML(totalPaginas) {
    const div = document.getElementById('pagination');
    if (totalPaginas <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    let start = Math.max(1, paginaActual - 2);
    let end = Math.min(totalPaginas, start + 4);
    if (end - start < 4) start = Math.max(1, end - 4);

    if (paginaActual > 1) {
      html += `<button class="page-link text-link" onclick="window.cambiarPagina(1)">« Inicio</button>`;
      html += `<button class="page-link text-link" onclick="window.cambiarPagina(${paginaActual-1})">Anterior</button>`;
    }
    
    for (let i = start; i <= end; i++) {
      html += `<button class="page-link ${i === paginaActual ? 'active' : ''}" onclick="window.cambiarPagina(${i})">${i}</button>`;
    }
    
    if (paginaActual < totalPaginas) {
      html += `<button class="page-link text-link" onclick="window.cambiarPagina(${paginaActual+1})">Siguiente</button>`;
      html += `<button class="page-link text-link" onclick="window.cambiarPagina(${totalPaginas})">Final »</button>`;
    }
    
    div.innerHTML = html;
  }
  window.cambiarPagina = (numPagina) => { paginaActual = numPagina; dibujarMatriz(); };

  // --- FILTRO ---
  document.getElementById('searchInput').addEventListener('input', (e) => {
    const termino = (e.target as HTMLInputElement).value.toLowerCase();
    modulosFiltrados = todosLosModulos.filter(m => m.strnombremodulo.toLowerCase().includes(termino));
    paginaActual = 1;
    dibujarMatriz();
  });

  // --- 4. GUARDAR LA MEMORIA EN LA BASE DE DATOS (El Gran Final) ---
  window.guardarMatrizCompleta = async () => {
    if (!permisos.editar && !permisos.agregar) {
        mostrarMensaje("No tienes permiso para modificar la matriz", "error");
        return;
    }

    const idPerfil = document.getElementById('selectPerfilMaster').value;
    const btn = document.getElementById('btnGuardarMatriz');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
    btn.disabled = true;

    const token = localStorage.getItem('token');
    let promesas = [];

    // Recorremos TODO el borrador (las 5 páginas juntas)
    Object.keys(matrizBorrador).forEach(idModulo => {
      const estado = matrizBorrador[idModulo];
      
      // ¡SOLO enviamos a la BD si el usuario hizo algún cambio! (Súper optimizado)
      if (estado.modificado) {
          const data = {
            idModulo: parseInt(idModulo),
            idPerfil: parseInt(idPerfil),
            bitConsulta: estado.c,
            bitAgregar: estado.a,
            bitEditar: estado.e,
            bitDetalle: estado.d,
            bitEliminar: estado.x
          };

          const tieneAlgunPermiso = estado.c || estado.a || estado.e || estado.d || estado.x;

          if (estado.idPermiso) {
              // Ya existía: actualizamos (incluso si los desmarcó todos para dejarlos en false)
              promesas.push(fetch(`${API_URL}/api/permisos-perfil/${estado.idPermiso}`, {
                method: 'PUT', headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` }, body: JSON.stringify(data)
              }));
          } else if (tieneAlgunPermiso) {
              // No existía, y marcó al menos uno: creamos nuevo registro
              promesas.push(fetch(`${API_URL}/api/permisos-perfil`, {
                method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` }, body: JSON.stringify(data)
              }));
          }
      }
    });

    if (promesas.length === 0) {
        mostrarMensaje('No se detectaron cambios para guardar', 'success');
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Matriz de Permisos';
        btn.disabled = false;
        return;
    }

    try {
      await Promise.all(promesas);
      mostrarMensaje('¡Permisos sincronizados correctamente!', 'success');
      // Recargamos fresco de la Base de datos
      await window.cargarMatrizDePerfil(idPerfil);
    } catch (error) {
      mostrarMensaje('Error al sincronizar la base de datos', 'error');
    } finally {
      btn.innerHTML = '<i class="fas fa-save"></i> Guardar Matriz de Permisos';
      btn.disabled = false;
    }
  };

  function mostrarMensaje(texto, tipo) {
    const msj = document.getElementById('message');
    msj.textContent = texto;
    msj.className = `status-message msg-${tipo}`;
    msj.style.display = 'block';
    setTimeout(() => { msj.style.display = 'none'; }, 3000);
  }

  document.addEventListener('DOMContentLoaded', inicializarVista);
</script>

<style is:global>
  /* MANTENEMOS TU DISEÑO INTACTO */
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border: 1px solid #f1f5f9;}
  .header-title h1 { margin: 0; color: #0f172a; font-size: 1.8rem; display: flex; align-items: center; gap: 10px; }
  .header-title p { margin: 5px 0 0 0; color: #64748b; font-size: 0.95rem; }
  
  .empty-state { text-align: center; padding: 5rem 2rem; background: white; border-radius: 12px; border: 1px dashed #cbd5e1; color: #94a3b8; }
  .empty-state i { font-size: 4rem; margin-bottom: 1rem; color: #e2e8f0; }
  .empty-state h2 { color: #475569; margin: 0 0 0.5rem 0; font-size: 1.4rem; }

  .form-group label { font-weight: 700; margin-bottom: 0.5rem; color: #334155; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;}
  .select-wrapper { position: relative; }
  .select-icon { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none; }
  .select-wrapper select { width: 100%; padding: 0.9rem; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; font-weight: 600; color: #1e293b; transition: all 0.2s; cursor: pointer; background: #f8fafc; appearance: none; -webkit-appearance: none; outline: none; }
  .select-wrapper select:focus { outline: none; border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);}

  .card-container { background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); padding: 1.5rem; border: 1px solid #f1f5f9; }
  .table-toolbar { margin-bottom: 1.5rem; display: flex; justify-content: flex-end; }
  .search-box { position: relative; width: 100%; max-width: 400px; }
  .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1.1rem; }
  .search-box input { width: 100%; padding: 0.9rem 1rem 0.9rem 2.8rem; border: 2px solid #e2e8f0; border-radius: 30px; font-size: 0.95rem; transition: border-color 0.2s; background: #f8fafc; color: #334155; outline: none; }
  .search-box input:focus { border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }

  .table-responsive { overflow-x: auto; border: 1px solid #e2e8f0; border-radius: 8px; }
  .crud-table { width: 100%; border-collapse: collapse; min-width: 700px; }
  .crud-table th { background: #1e3a8a; color: white; padding: 12px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; border-right: 1px solid rgba(255,255,255,0.1); }
  .crud-table th.text-center { text-align: center; }
  .crud-table th:first-child { padding-left: 15px; }
  .crud-table td { padding: 12px; border-bottom: 1px solid #f1f5f9; border-right: 1px solid #f1f5f9; }
  .crud-table tbody tr:hover { background-color: #f8fafc; }
  .text-center { text-align: center !important; }
  .no-data { text-align: center; color: #94a3b8; padding: 3rem !important; }
  
  .permiso-item { display: inline-flex; align-items: center; justify-content: center; cursor: pointer; margin: 0; }
  .permiso-item input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
  .checkmark { height: 18px; width: 18px; background-color: white; border: 2px solid #cbd5e1; border-radius: 4px; display: block; position: relative; transition: 0.1s; }
  .checkmark:after { content: ""; position: absolute; display: none; left: 5px; top: 1px; width: 4px; height: 9px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); }
  .permiso-item input:checked ~ .checkmark { background-color: #2563eb; border-color: #2563eb; }
  .permiso-item input:checked ~ .checkmark:after { display: block; }

  .btn-primary { background: #1e3a8a; color: white; border: none; padding: 0.9rem 2rem; border-radius: 8px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px; transition: background 0.2s; font-size: 1rem;}
  .btn-primary:hover { background: #172554; }
  .btn-primary:disabled { background: #94a3b8; cursor: not-allowed; }

  .pagination { display: flex; justify-content: flex-end; gap: 4px; }
  .page-link { padding: 6px 12px; border: 1px solid #e2e8f0; background: white; color: #475569; border-radius: 4px; cursor: pointer; font-size: 0.85rem; transition: 0.2s; }
  .page-link:hover:not(.active) { background: #f8fafc; }
  .page-link.active { background: #1e3a8a; color: white; border-color: #1e3a8a; }
  .page-link.text-link { color: #64748b; }

  .status-message { position: fixed; bottom: 20px; right: 20px; padding: 12px 24px; border-radius: 8px; display: none; font-weight: 600; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); z-index: 9999; animation: slideUp 0.3s ease-out; color: white;}
  .msg-success { background: #10b981; }
  .msg-error { background: #ef4444; }
  @keyframes slideUp { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>