---
import Layout from '../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Acceso al Sistema | ERP">
  <script src="https://js.hcaptcha.com/1/api.js" async defer is:inline></script>

  <div class="login-card">
    <div class="login-header">
      <i class="fas fa-user-circle"></i>
      <h2>Iniciar Sesión</h2>
      <p>Ingrese sus credenciales corporativas</p>
    </div>

    <form id="loginForm" data-api-url={API_URL}>
      <div class="input-group">
        <label for="loginIdentifier">Usuario o Email</label>
        <div class="input-wrapper">
          <i class="fas fa-user"></i>
          <input type="text" id="loginIdentifier" name="username" placeholder="admin" required maxlength="50">
        </div>
      </div>

      <div class="input-group">
        <label for="loginPassword">Contraseña</label>
        <div class="input-wrapper">
          <i class="fas fa-lock"></i>
          <input type="password" id="loginPassword" name="password" placeholder="••••••••" required maxlength="50">
        </div>
        <div style="text-align: right; margin-top: 8px;">
          <a href="#" onclick="abrirModalRecuperar(event)" style="font-size: 0.85rem; color: #3b82f6; text-decoration: none; font-weight: 600;">¿Olvidaste tu contraseña?</a>
        </div>
      </div>

      <div class="input-group" style="display: flex; justify-content: center; margin-bottom: 1.5rem;">
         <div class="h-captcha" data-sitekey="10000000-ffff-ffff-ffff-000000000001"></div>
      </div>

      <button type="submit" id="btnSubmit">
        <span>Ingresar al Sistema</span>
        <i class="fas fa-arrow-right"></i>
      </button>
    </form>

    <div id="message" class="status-message"></div>
  </div>

  <div id="modalRecuperar" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Recuperar Contraseña</h3>
        <button class="close-btn" onclick="cerrarModalRecuperar()">&times;</button>
      </div>
      <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 1.5rem;">Ingresa el correo electrónico asociado a tu cuenta. Te enviaremos un enlace seguro para restablecer tu acceso.</p>
      
      <form id="recuperarForm">
        <div class="input-group">
          <label for="emailRecuperar">Correo Electrónico</label>
          <div class="input-wrapper">
            <i class="fas fa-envelope"></i>
            <input type="email" id="emailRecuperar" required placeholder="correo@empresa.com" maxlength="50">
          </div>
        </div>
        <button type="submit" id="btnRecuperar" style="margin-top: 1rem;">
          <i class="fas fa-paper-plane"></i> Enviar Enlace
        </button>
      </form>
      <div id="msgRecuperar" class="status-message" style="margin-top: 1rem;"></div>
    </div>
  </div>
</Layout>

<style>
    .login-card { max-width: 420px; margin: 4rem auto; padding: 2rem; background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .login-header { text-align: center; margin-bottom: 2rem; }
    .login-header i { font-size: 3.5rem; color: #3b82f6; margin-bottom: 1rem; }
    .input-group { margin-bottom: 1.25rem; }
    .input-group label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; color: #475569; }
    .input-wrapper { position: relative; display: flex; align-items: center; }
    .input-wrapper i { position: absolute; left: 1rem; color: #94a3b8; }
    .input-wrapper input { width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid #e2e8f0; border-radius: 8px; }
    button { width: 100%; padding: 0.8rem; background: #1e293b; color: white; border: none; border-radius: 8px; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; font-weight: 600; transition: background 0.2s; }
    button:hover { background: #334155; }
    .status-message { margin-top: 1.5rem; padding: 0.8rem; border-radius: 6px; display: none; text-align: center; font-size: 0.9rem; }
    
    .modal { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
    .modal-content { background: white; padding: 2rem; border-radius: 12px; width: 100%; max-width: 400px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .modal-header h3 { margin: 0; color: #0f172a; font-size: 1.25rem; }
    .close-btn { background: #f1f5f9; border: none; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #64748b; padding:0; }
    .close-btn:hover { background: #fee2e2; color: #ef4444; }
</style>

<script>
  const API_URL = "https://extra-earth-production.up.railway.app";

  const setupLoginForm = () => {
    const form = document.getElementById("loginForm");
    if (!form) return;

    const messageDiv = document.getElementById("message");
    const btnSubmit = document.getElementById("btnSubmit");
    const apiUrl = form.dataset.apiUrl;

    const showMsg = (text, type) => {
      if (!messageDiv) return;
      messageDiv.style.display = "block";
      messageDiv.style.background = type === "success" ? "#dcfce7" : "#fee2e2";
      messageDiv.style.color = type === "success" ? "#166534" : "#991b1b";
      messageDiv.textContent = text;
    };

    form.onsubmit = async (e) => {
      e.preventDefault();
      const hcaptchaElement = document.querySelector('[name="h-captcha-response"]');
      if (!hcaptchaElement || !hcaptchaElement.value) { 
        showMsg("Resuelva el captcha", "error"); 
        return; 
      }

      btnSubmit.disabled = true;
      btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Entrando...';

      try {
        const res = await fetch(`${apiUrl}/api/login`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            username: document.getElementById("loginIdentifier").value,
            password: document.getElementById("loginPassword").value
          })
        });

        const data = await res.json();
        if (res.ok && data.success) {
          localStorage.clear();
          localStorage.setItem("token", data.token);
          localStorage.setItem("user", JSON.stringify(data.user));
          localStorage.setItem("permisos", JSON.stringify(data.permisos || []));
          
          showMsg("Bienvenido", "success");
          
          setTimeout(() => { 
            window.location.href = "/extra-earth/modulos/bienvenida/"; 
          }, 1000);
        } else {
          showMsg(data.message || "Error", "error");
          btnSubmit.disabled = false;
          btnSubmit.innerHTML = '<span>Ingresar al Sistema</span><i class="fas fa-arrow-right"></i>';
        }
      } catch (err) {
        showMsg("Error de conexión", "error");
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = '<span>Ingresar al Sistema</span><i class="fas fa-arrow-right"></i>';
      }
    };
  };

  window.abrirModalRecuperar = (e) => {
    e.preventDefault();
    document.getElementById('modalRecuperar').style.display = 'flex';
  };

  window.cerrarModalRecuperar = () => {
    document.getElementById('modalRecuperar').style.display = 'none';
    const form = document.getElementById('recuperarForm');
    if(form) form.reset();
    document.getElementById('msgRecuperar').style.display = 'none';
  };

  document.addEventListener('DOMContentLoaded', () => {
    setupLoginForm();

    document.getElementById('recuperarForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btnRecuperar = document.getElementById('btnRecuperar');
      const msgDiv = document.getElementById('msgRecuperar');
      const email = document.getElementById('emailRecuperar').value;

      btnRecuperar.disabled = true;
      btnRecuperar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';

      try {
        const res = await fetch(`${API_URL}/api/forgot-password`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email })
        });
        const data = await res.json();
        
        msgDiv.style.display = "block";
        msgDiv.style.background = "#dcfce7";
        msgDiv.style.color = "#166534";
        msgDiv.textContent = data.message;
        
      } catch (err) {
        msgDiv.style.display = "block";
        msgDiv.style.background = "#fee2e2";
        msgDiv.style.color = "#991b1b";
        msgDiv.textContent = "Error al conectar con el servidor.";
      } finally {
        btnRecuperar.disabled = false;
        btnRecuperar.innerHTML = '<i class="fas fa-paper-plane"></i> Enviar Enlace';
      }
    });
  });
</script>