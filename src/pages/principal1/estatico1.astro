---
import Layout from '../../layout/layout.astro';
---

<Layout title="Principal 1.1 | Sistema Corporativo">
  <div class="static-module">
    <div class="module-header">
      <h2><i class="fas fa-file"></i> Módulo Principal 1.1</h2>
      <p>Este es un módulo estático con botones de CRUD sin funcionalidad real</p>
    </div>

    <div class="crud-actions">
      <button class="btn-add" onclick="alert('Funcionalidad no implementada en módulo estático')">
        <i class="fas fa-plus"></i> Agregar
      </button>
      <button class="btn-edit" onclick="alert('Funcionalidad no implementada en módulo estático')">
        <i class="fas fa-edit"></i> Editar
      </button>
      <button class="btn-delete" onclick="alert('Funcionalidad no implementada en módulo estático')">
        <i class="fas fa-trash"></i> Eliminar
      </button>
      <button class="btn-view" onclick="alert('Funcionalidad no implementada en módulo estático')">
        <i class="fas fa-eye"></i> Consultar
      </button>
      <button class="btn-detail" onclick="alert('Funcionalidad no implementada en módulo estático')">
        <i class="fas fa-info-circle"></i> Detalle
      </button>
    </div>

    <div class="static-content">
      <p>Contenido de ejemplo para el módulo estático Principal 1.1</p>
      <p>Este módulo solo muestra la interfaz sin conexión a base de datos.</p>
    </div>
  </div>
</Layout>

<style>
  .static-module {
    padding: 1rem;
  }

  .module-header {
    margin-bottom: 2rem;
  }

  .module-header h2 {
    margin: 0 0 0.5rem 0;
    color: #1e293b;
  }

  .module-header h2 i {
    color: #3b82f6;
    margin-right: 0.5rem;
  }

  .module-header p {
    color: #64748b;
    margin: 0;
  }

  .crud-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding: 1rem;
    background: #f8fafc;
    border-radius: 8px;
  }

  .crud-actions button {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-add {
    background: #059669;
    color: white;
  }

  .btn-add:hover {
    background: #047857;
  }

  .btn-edit {
    background: #f59e0b;
    color: white;
  }

  .btn-edit:hover {
    background: #d97706;
  }

  .btn-delete {
    background: #ef4444;
    color: white;
  }

  .btn-delete:hover {
    background: #dc2626;
  }

  .btn-view {
    background: #3b82f6;
    color: white;
  }

  .btn-view:hover {
    background: #2563eb;
  }

  .btn-detail {
    background: #8b5cf6;
    color: white;
  }

  .btn-detail:hover {
    background: #7c3aed;
  }

  .static-content {
    padding: 2rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-align: center;
    color: #64748b;
  }

  @media (max-width: 640px) {
    .crud-actions {
      flex-direction: column;
    }
    
    .crud-actions button {
      width: 100%;
      justify-content: center;
    }
  }
</style>