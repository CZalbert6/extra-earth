---
// src/pages/reset-password.astro
// IMPORTANTE: Ya NO importamos el Layout aquí para evitar que nos expulse al login.
const API_URL = "https://extra-earth-production.up.railway.app";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Restablecer Contraseña | ERP</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

  <div class="login-card">
    <div class="login-header">
      <div class="icon-container">
        <i class="fas fa-unlock-alt"></i>
      </div>
      <h2>Nueva Contraseña</h2>
      <p>Crea una contraseña segura para tu cuenta</p>
    </div>

    <div id="pantallaError" style="display: none; text-align: center; padding: 1rem 0;">
      <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: #ef4444; margin-bottom: 1rem;"></i>
      <h3 style="color: #0f172a; margin-bottom: 0.5rem;">Enlace Inválido</h3>
      <p style="color: #64748b; margin-bottom: 1.5rem; font-size: 0.95rem;">El enlace de recuperación no existe, está mal escrito o ya caducó (el límite es de 15 minutos).</p>
      <a href="/extra-earth/login" class="btn-return"><i class="fas fa-arrow-left"></i> Volver al Login</a>
    </div>

    <form id="resetForm" data-api-url={API_URL} style="display: none;">
      <div class="input-group">
        <label for="newPassword">Nueva Contraseña</label>
        <div class="input-wrapper">
          <i class="fas fa-lock"></i>
          <input type="password" id="newPassword" required minlength="6" placeholder="Mínimo 6 caracteres">
        </div>
      </div>

      <div class="input-group">
        <label for="confirmPassword">Confirmar Contraseña</label>
        <div class="input-wrapper">
          <i class="fas fa-check-circle"></i>
          <input type="password" id="confirmPassword" required minlength="6" placeholder="Repite la contraseña">
        </div>
      </div>

      <button type="submit" id="btnSubmit">
        <i class="fas fa-save"></i>
        <span>Guardar Contraseña</span>
      </button>
    </form>

    <div id="message" class="status-message"></div>
  </div>

</body>
</html>

<style>
    /* Estilos globales básicos que antes te daba el Layout */
    body {
      background-color: #f1f5f9;
      font-family: system-ui, -apple-system, sans-serif;
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* Tus estilos originales intactos */
    .login-card { width: 100%; max-width: 420px; padding: 2.5rem; background: white; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); border: 1px solid #e2e8f0; box-sizing: border-box; margin: 1rem;}
    
    .login-header { text-align: center; margin-bottom: 2rem; }
    .icon-container { width: 70px; height: 70px; background: #dcfce7; color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1rem auto; box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2); }
    .login-header h2 { margin:0; color: #0f172a; font-size: 1.6rem; }
    .login-header p { color: #64748b; margin-top: 5px; font-size: 0.95rem; }
    
    .input-group { margin-bottom: 1.5rem; }
    .input-group label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; color: #475569; text-transform: uppercase; letter-spacing: 0.5px;}
    .input-wrapper { position: relative; display: flex; align-items: center; }
    .input-wrapper i { position: absolute; left: 1rem; color: #94a3b8; }
    .input-wrapper input { width: 100%; padding: 0.85rem 1rem 0.85rem 2.8rem; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; transition: border-color 0.2s; background: #f8fafc; color: #1e293b; box-sizing: border-box;}
    .input-wrapper input:focus { outline: none; border-color: #10b981; background: white; box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1); }
    
    button { width: 100%; padding: 0.9rem; background: #10b981; color: white; border: none; border-radius: 8px; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; font-weight: 600; font-size: 1rem; transition: all 0.2s; margin-top: 1rem; box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2); box-sizing: border-box;}
    button:hover { background: #059669; transform: translateY(-2px); }
    button:disabled { background: #94a3b8; cursor: not-allowed; transform: none; box-shadow: none; }
    
    .btn-return { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 0.8rem 1.5rem; background: #f1f5f9; color: #475569; border-radius: 8px; text-decoration: none; font-weight: 600; transition: background 0.2s; width: 100%; box-sizing: border-box;}
    .btn-return:hover { background: #e2e8f0; }

    .status-message { margin-top: 1.5rem; padding: 1rem; border-radius: 8px; display: none; text-align: center; font-weight: 600; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Extraer el token de la URL
    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');

    const form = document.getElementById("resetForm");
    const pantallaError = document.getElementById("pantallaError");

    // Si alguien entra a la página directamente sin un token, le mostramos error
    if (!token) {
      if(pantallaError) pantallaError.style.display = 'block';
      return;
    }

    // Si hay token, revelamos el formulario
    if(form) form.style.display = 'block';

    const messageDiv = document.getElementById("message");
    const btnSubmit = document.getElementById("btnSubmit") as HTMLButtonElement;
    
    const apiUrl = form?.dataset.apiUrl;

    const showMsg = (text: string, type: string) => {
      if(!messageDiv) return;
      messageDiv.style.display = "block";
      messageDiv.style.background = type === "success" ? "#dcfce7" : "#fee2e2";
      messageDiv.style.color = type === "success" ? "#166534" : "#991b1b";
      messageDiv.textContent = text;
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const newPassword = (document.getElementById("newPassword") as HTMLInputElement).value;
      const confirmPassword = (document.getElementById("confirmPassword") as HTMLInputElement).value;

      if (newPassword !== confirmPassword) {
        showMsg("Las contraseñas no coinciden. Inténtalo de nuevo.", "error");
        return;
      }

      btnSubmit.disabled = true;
      btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

      try {
        const res = await fetch(`${apiUrl}/api/reset-password`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, newPassword })
        });

        const data = await res.json();
        
        if (data.success) {
          showMsg("Contraseña actualizada con éxito. Redirigiendo al login...", "success");
          form.style.display = 'none';
          
          setTimeout(() => { window.location.href = "/extra-earth/login"; }, 2500);
        } else {
          showMsg(data.message, "error");
          btnSubmit.disabled = false;
          btnSubmit.innerHTML = '<i class="fas fa-save"></i> Guardar Contraseña';
        }
      } catch (err) {
        showMsg("Error de conexión con el servidor. Revisa tu internet.", "error");
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = '<i class="fas fa-save"></i> Guardar Contraseña';
      }
    });
  });
</script>