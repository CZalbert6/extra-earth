---
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Gestión de Módulos";
---

<Layout title={`${pageTitle} | Sistema Corporativo`} moduloActual="Módulo">
  <div class="page-header">
    <h1><i class="fas fa-puzzle-piece"></i> {pageTitle}</h1>
    <button class="btn-add" id="btnNuevoModulo" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Módulo
    </button>
  </div>

  <div id="modalModulo" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Módulo</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="moduloForm" onsubmit="event.preventDefault(); guardarModulo();">
        <input type="hidden" id="moduloId">
        
        <div class="form-group">
          <label for="strNombreModulo">Nombre del Módulo *</label>
          <input type="text" id="strNombreModulo" required maxlength="100">
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="loading" style="display: none; text-align: center; padding: 2rem;">
    <i class="fas fa-spinner fa-spin fa-2x"></i>
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaModulos">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre</th>
          <th>Fecha Creación</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="4" class="no-data">Cargando módulos...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  let currentPage = 1;
  // 1. Obtener permisos del usuario logueado para este módulo
  const { permisos } = verificarPermisosModulo('Módulo');

  async function cargarModulos(page = 1) {
    if (!permisos.consulta) return;
    
    document.getElementById('loading').style.display = 'block';
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/modulos?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      showMsg('Error al cargar módulos', 'error');
    } finally {
      document.getElementById('loading').style.display = 'none';
    }
  }

  function renderizarTabla(modulos) {
    const tbody = document.getElementById('tablaBody');
    if (modulos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="4" class="no-data">No hay módulos registrados</td></tr>';
      return;
    }
    
    tbody.innerHTML = modulos.map(m => `
      <tr>
        <td>${m.id}</td>
        <td><strong>${m.strnombremodulo}</strong></td>
        <td>${new Date(m.created_at).toLocaleDateString()}</td>
        <td class="actions-cell">
          ${permisos.detalle ? `<button class="btn-icon view" onclick="verDetalle(${m.id})" title="Ver detalle"><i class="fas fa-eye"></i></button>` : ''}
          ${permisos.editar ? `<button class="btn-icon edit" onclick="editarModulo(${m.id})" title="Editar"><i class="fas fa-edit"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="btn-icon delete" onclick="eliminarModulo(${m.id})" title="Eliminar"><i class="fas fa-trash"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacion(pagination) {
    const div = document.getElementById('pagination');
    if (pagination.totalPages <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="window.cargarModulos(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  // Hacer funciones disponibles globalmente para los onclick de los botones inyectados
  window.cargarModulos = cargarModulos;

  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Nuevo Módulo';
    document.getElementById('moduloForm').reset();
    document.getElementById('moduloId').value = '';
    document.getElementById('modalModulo').style.display = 'flex';
  };

  window.cerrarModal = () => {
    document.getElementById('modalModulo').style.display = 'none';
  };

  window.editarModulo = async (id) => {
    try {
      const token = localStorage.getItem('token');
      const res = await fetch(`${API_URL}/api/modulos/${id}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await res.json();
      if (data.success) {
        const m = data.data;
        document.getElementById('modalTitulo').textContent = 'Editar Módulo';
        document.getElementById('moduloId').value = m.id;
        document.getElementById('strNombreModulo').value = m.strnombremodulo;
        document.getElementById('modalModulo').style.display = 'flex';
      }
    } catch (error) { showMsg('Error al cargar', 'error'); }
  };

  window.verDetalle = async (id) => {
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/modulos/${id}`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await res.json();
    if (data.success) {
      alert(`ID: ${data.data.id}\nNombre: ${data.data.strnombremodulo}\nCreado: ${new Date(data.data.created_at).toLocaleString()}`);
    }
  };

  window.guardarModulo = async () => {
    const id = document.getElementById('moduloId').value;
    const nombre = document.getElementById('strNombreModulo').value.trim();
    const token = localStorage.getItem('token');
    
    const response = await fetch(id ? `${API_URL}/api/modulos/${id}` : `${API_URL}/api/modulos`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify({ strNombreModulo: nombre })
    });
    
    if ((await response.json()).success) {
      showMsg(id ? 'Actualizado' : 'Creado', 'success');
      cerrarModal();
      cargarModulos(currentPage);
    }
  };

  window.eliminarModulo = async (id) => {
    if (!confirm('¿Eliminar módulo?')) return;
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/modulos/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    if ((await res.json()).success) {
      showMsg('Eliminado', 'success');
      cargarModulos(currentPage);
    }
  };

  function showMsg(text, type) {
    const msgDiv = document.getElementById('message');
    msgDiv.style.display = 'block';
    msgDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
    msgDiv.textContent = text;
    setTimeout(() => msgDiv.style.display = 'none', 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) document.getElementById('btnNuevoModulo').style.display = 'block';
    cargarModulos();
  });
</script>

<style>
  /* Mantener tus estilos anteriores */
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-add { background: #059669; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
  .modal-content { background: white; padding: 2rem; border-radius: 8px; width: 100%; max-width: 450px; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
  .form-group input { padding: 0.7rem; border: 1px solid #ddd; border-radius: 4px; }
  .form-actions { display: flex; justify-content: flex-end; gap: 10px; }
  .crud-table { width: 100%; border-collapse: collapse; background: white; }
  .crud-table th, .crud-table td { padding: 1rem; border-bottom: 1px solid #eee; text-align: left; }
  .btn-icon { border: none; background: none; cursor: pointer; padding: 5px; }
  .edit { color: #f59e0b; } .delete { color: #ef4444; } .view { color: #3b82f6; }
  .status-message { position: fixed; bottom: 20px; right: 20px; padding: 10px 20px; border-radius: 5px; display: none; z-index: 1100; }
</style>