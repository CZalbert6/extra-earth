---
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="GestiÃ³n de Usuarios">
  <div class="page-header">
    <h1><i class="fas fa-users"></i> GestiÃ³n de Usuarios</h1>
    <button class="btn-add" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Usuario
    </button>
  </div>

  <!-- Modal -->
  <div id="modalUsuario" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Usuario</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="usuarioForm" onsubmit="event.preventDefault(); guardarUsuario();">
        <input type="hidden" id="usuarioId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Usuario *</label>
            <input type="text" id="strNombreUsuario" required maxlength="100">
          </div>
          
          <div class="form-group">
            <label>Correo *</label>
            <input type="email" id="strCorreo" required>
          </div>
          
          <div class="form-group">
            <label>TelÃ©fono</label>
            <input type="text" id="strNumeroCelular">
          </div>
          
          <div class="form-group">
            <label>Perfil</label>
            <select id="idPerfil">
              <option value="">Seleccione...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Estado</label>
            <select id="idEstadoUsuario">
              <option value="1">Activo</option>
              <option value="0">Inactivo</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>ContraseÃ±a</label>
            <input type="password" id="strPwd" minlength="6">
            <small>MÃ­nimo 6 caracteres. Dejar vacÃ­o para no cambiar.</small>
          </div>
        </div>
        
        <!-- Imagen -->
        <div class="form-group imagen-group">
          <label>Foto de Perfil</label>
          <div class="imagen-preview" id="imagenPreview">
            <img id="previewImg" src="#" alt="Vista previa" style="display: none;">
            <div class="preview-placeholder" id="previewPlaceholder">
              <i class="fas fa-user"></i>
            </div>
          </div>
          
          <div class="imagen-input">
            <input type="file" id="imagenFile" accept="image/jpeg,image/png,image/gif" onchange="previsualizarImagen(event)">
            <button type="button" class="btn-clear" onclick="limpiarImagen()" style="display: none;" id="btnClearImagen">
              <i class="fas fa-times"></i> Quitar imagen
            </button>
          </div>
          <input type="hidden" id="strImagenBase64">
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Tabla -->
  <div id="loading" style="display: none; text-align: center;">
    <i class="fas fa-spinner fa-spin"></i> Cargando...
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaUsuarios">
      <thead>
        <tr>
          <th>ID</th>
          <th>Foto</th>
          <th>Usuario</th>
          <th>Correo</th>
          <th>TelÃ©fono</th>
          <th>Perfil</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="8" class="no-data">Cargando usuarios...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script define:vars={{ API_URL }}>
  let currentPage = 1;
  let currentItem = null;
  let perfilesList = [];

  window.previsualizarImagen = (event) => {
    const file = event.target.files[0];
    if (file) {
      if (!file.type.match('image.*')) {
        showMsg('Por favor, seleccione una imagen vÃ¡lida', 'error');
        return;
      }
      
      if (file.size > 5 * 1024 * 1024) {
        showMsg('La imagen no debe superar 5MB', 'error');
        return;
      }
      
      const reader = new FileReader();
      reader.onload = (e) => {
        const base64 = e.target.result;
        document.getElementById('strImagenBase64').value = base64;
        document.getElementById('previewImg').src = base64;
        document.getElementById('previewImg').style.display = 'block';
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      };
      reader.readAsDataURL(file);
    }
  };

  window.limpiarImagen = () => {
    document.getElementById('imagenFile').value = '';
    document.getElementById('strImagenBase64').value = '';
    document.getElementById('previewImg').style.display = 'none';
    document.getElementById('previewPlaceholder').style.display = 'flex';
    document.getElementById('btnClearImagen').style.display = 'none';
  };

  async function cargarPerfiles() {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/perfiles-lista`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        perfilesList = data.data;
        const select = document.getElementById('idPerfil');
        select.innerHTML = '<option value="">Seleccione...</option>' + 
          data.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
      }
    } catch (error) {
      console.error('Error cargando perfiles:', error);
    }
  }

  async function cargarUsuarios(page = 1) {
    document.getElementById('loading').style.display = 'block';
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      showMsg('Error al cargar usuarios', 'error');
    } finally {
      document.getElementById('loading').style.display = 'none';
    }
  }

  function renderizarTabla(usuarios) {
    const tbody = document.getElementById('tablaBody');
    
    if (usuarios.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="no-data">No hay usuarios registrados</td></tr>';
      return;
    }
    
    tbody.innerHTML = usuarios.map(u => `
      <tr>
        <td>${u.id}</td>
        <td>
          ${u.strimagen ? 
            `<img src="${u.strimagen}" alt="Foto" class="foto-perfil-tabla">` : 
            '<i class="fas fa-user-circle" style="font-size: 2rem; color: #94a3b8;"></i>'}
        </td>
        <td>${u.strnombreusuario}</td>
        <td>${u.strcorreo}</td>
        <td>${u.strnumerocelular || '-'}</td>
        <td>${u.strnombreperfil || 'Sin perfil'}</td>
        <td>
          <span class="badge ${u.idestadousuario === 1 ? 'badge-active' : 'badge-inactive'}">
            ${u.idestadousuario === 1 ? 'Activo' : 'Inactivo'}
          </span>
        </td>
        <td class="actions-cell">
          <button class="btn-icon view" onclick="verDetalle(${u.id})" title="Ver detalle">
            <i class="fas fa-eye"></i>
          </button>
          <button class="btn-icon edit" onclick="editarUsuario(${u.id})" title="Editar">
            <i class="fas fa-edit"></i>
          </button>
          <button class="btn-icon delete" onclick="eliminarUsuario(${u.id})" title="Eliminar">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacion(pagination) {
    const paginationDiv = document.getElementById('pagination');
    if (pagination.totalPages <= 1) {
      paginationDiv.innerHTML = '';
      return;
    }
    
    let html = '<div class="pagination">';
    html += `<button ${pagination.page === 1 ? 'disabled' : ''} onclick="cargarUsuarios(${pagination.page - 1})">
      <i class="fas fa-chevron-left"></i>
    </button>`;
    
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="cargarUsuarios(${i})">${i}</button>`;
    }
    
    html += `<button ${pagination.page === pagination.totalPages ? 'disabled' : ''} onclick="cargarUsuarios(${pagination.page + 1})">
      <i class="fas fa-chevron-right"></i>
    </button>`;
    html += '</div>';
    
    paginationDiv.innerHTML = html;
  }

  window.abrirModalNuevo = () => {
    currentItem = null;
    document.getElementById('modalTitulo').textContent = 'Nuevo Usuario';
    document.getElementById('usuarioForm').reset();
    document.getElementById('usuarioId').value = '';
    document.getElementById('strPwd').required = true;
    limpiarImagen();
    document.getElementById('modalUsuario').style.display = 'flex';
  };

  window.cerrarModal = () => {
    document.getElementById('modalUsuario').style.display = 'none';
  };

  window.editarUsuario = async (id) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        const user = data.data;
        currentItem = user;
        
        document.getElementById('modalTitulo').textContent = 'Editar Usuario';
        document.getElementById('usuarioId').value = user.id;
        document.getElementById('strNombreUsuario').value = user.strnombreusuario;
        document.getElementById('strCorreo').value = user.strcorreo;
        document.getElementById('strNumeroCelular').value = user.strnumerocelular || '';
        document.getElementById('idPerfil').value = user.idperfil || '';
        document.getElementById('idEstadoUsuario').value = user.idestadousuario;
        document.getElementById('strPwd').required = false;
        document.getElementById('strPwd').value = '';
        
        if (user.strimagen) {
          document.getElementById('strImagenBase64').value = user.strimagen;
          document.getElementById('previewImg').src = user.strimagen;
          document.getElementById('previewImg').style.display = 'block';
          document.getElementById('previewPlaceholder').style.display = 'none';
          document.getElementById('btnClearImagen').style.display = 'inline-block';
        } else {
          limpiarImagen();
        }
        
        document.getElementById('modalUsuario').style.display = 'flex';
      }
    } catch (error) {
      showMsg('Error al cargar usuario', 'error');
    }
  };

  window.verDetalle = async (id) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        const user = data.data;
        alert(`
          ID: ${user.id}
          Usuario: ${user.strnombreusuario}
          Correo: ${user.strcorreo}
          TelÃ©fono: ${user.strnumerocelular || 'N/A'}
          Perfil: ${user.strnombreperfil || 'Sin perfil'}
          Estado: ${user.idestadousuario === 1 ? 'Activo' : 'Inactivo'}
        `);
      }
    } catch (error) {
      showMsg('Error al cargar detalle', 'error');
    }
  };

  window.guardarUsuario = async () => {
    const usuarioData = {
      strNombreUsuario: document.getElementById('strNombreUsuario').value.trim(),
      strCorreo: document.getElementById('strCorreo').value.trim(),
      strNumeroCelular: document.getElementById('strNumeroCelular').value.trim() || null,
      idPerfil: document.getElementById('idPerfil').value || null,
      idEstadoUsuario: parseInt(document.getElementById('idEstadoUsuario').value),
      strImagenBase64: document.getElementById('strImagenBase64').value || null
    };
    
    const password = document.getElementById('strPwd').value;
    const usuarioId = document.getElementById('usuarioId').value;
    
    if (!usuarioData.strNombreUsuario || !usuarioData.strCorreo) {
      showMsg('Usuario y correo son requeridos', 'error');
      return;
    }
    
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(usuarioData.strCorreo)) {
      showMsg('Correo invÃ¡lido', 'error');
      return;
    }
    
    if (!usuarioId && !password) {
      showMsg('ContraseÃ±a requerida para nuevo usuario', 'error');
      return;
    }
    
    if (password && password.length < 6) {
      showMsg('La contraseÃ±a debe tener al menos 6 caracteres', 'error');
      return;
    }
    
    if (password) {
      usuarioData.strPwd = password;
    }
    
    try {
      const token = localStorage.getItem('token');
      const url = usuarioId ? `${API_URL}/api/usuarios/${usuarioId}` : `${API_URL}/api/usuarios`;
      const method = usuarioId ? 'PUT' : 'POST';
      
      const response = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(usuarioData)
      });
      
      const data = await response.json();
      
      if (data.success) {
        showMsg(usuarioId ? 'Usuario actualizado' : 'Usuario creado', 'success');
        cerrarModal();
        cargarUsuarios(currentPage);
      } else {
        showMsg(data.message, 'error');
      }
    } catch (error) {
      showMsg('Error al guardar usuario', 'error');
    }
  };

  window.eliminarUsuario = async (id) => {
    if (!confirm('Â¿EstÃ¡ seguro de eliminar este usuario?')) return;
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        showMsg('Usuario eliminado', 'success');
        cargarUsuarios(currentPage);
      } else {
        showMsg(data.message, 'error');
      }
    } catch (error) {
      showMsg('Error al eliminar usuario', 'error');
    }
  };

  function showMsg(text, type) {
    const msgDiv = document.getElementById('message');
    msgDiv.style.display = 'block';
    msgDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
    msgDiv.style.color = type === 'success' ? '#166534' : '#991b1b';
    msgDiv.textContent = text;
    
    setTimeout(() => {
      msgDiv.style.display = 'none';
    }, 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    cargarPerfiles();
    cargarUsuarios();
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: 1.75rem;
    color: #1e293b;
  }

  .page-header h1 i {
    margin-right: 0.5rem;
    color: #3b82f6;
  }

  .btn-add {
    background: #059669;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    font-size: 1rem;
  }

  .btn-add:hover {
    background: #047857;
  }

  .modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
  }

  .modal-content {
    background: white;
    border-radius: 8px;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h3 {
    margin: 0;
    color: #1e293b;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #64748b;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    color: #475569;
  }

  .form-group input, .form-group select {
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 1rem;
  }

  .form-group input:focus, .form-group select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .imagen-group {
    grid-column: span 2;
    margin-top: 1rem;
    padding: 1rem;
    background: #f8fafc;
    border-radius: 8px;
  }

  .imagen-preview {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    overflow: hidden;
    border: 3px solid #e2e8f0;
  }

  .imagen-preview img, .preview-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-placeholder {
    background: #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: #94a3b8;
  }

  .imagen-input {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-clear {
    background: #ef4444;
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    cursor: pointer;
  }

  .btn-clear:hover {
    background: #dc2626;
  }

  .form-actions {
    padding: 1.5rem;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .btn-primary, .btn-secondary {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
  }

  .btn-primary {
    background: #1e293b;
    color: white;
  }

  .btn-primary:hover {
    background: #334155;
  }

  .btn-secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .btn-secondary:hover {
    background: #e2e8f0;
  }

  .table-responsive {
    overflow-x: auto;
    background: white;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  .crud-table {
    width: 100%;
    border-collapse: collapse;
  }

  .crud-table th {
    text-align: left;
    padding: 1rem;
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
    color: #475569;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .crud-table td {
    padding: 1rem;
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
  }

  .crud-table tr:hover {
    background: #f8fafc;
  }

  .foto-perfil-tabla {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }

  .badge {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .badge-active {
    background: #dcfce7;
    color: #166534;
  }

  .badge-inactive {
    background: #fee2e2;
    color: #991b1b;
  }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
  }

  .btn-icon {
    background: none;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .btn-icon.view {
    color: #3b82f6;
  }
  
  .btn-icon.edit {
    color: #f59e0b;
  }
  
  .btn-icon.delete {
    color: #ef4444;
  }

  .btn-icon:hover {
    background: #f1f5f9;
    transform: scale(1.1);
  }

  .no-data {
    text-align: center;
    color: #94a3b8;
    padding: 2rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .pagination button {
    padding: 0.5rem 1rem;
    border: 1px solid #e2e8f0;
    background: white;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .pagination button:hover:not(:disabled) {
    background: #f8fafc;
    border-color: #94a3b8;
  }

  .pagination button.active {
    background: #1e293b;
    color: white;
    border-color: #1e293b;
  }

  .pagination button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status-message {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 1rem;
    border-radius: 6px;
    display: none;
    z-index: 1100;
    animation: slideInRight 0.3s ease;
  }

  @keyframes slideInRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .imagen-group {
      grid-column: span 1;
    }

    .page-header {
      flex-direction: column;
      align-items: stretch;
    }

    .status-message {
      bottom: 1rem;
      right: 1rem;
      left: 1rem;
    }
  }
</style>