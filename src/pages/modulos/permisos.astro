---
// src/pages/modulos/permisos.astro
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Gestión de Permisos por Perfil";
---

<Layout title={`${pageTitle} | Sistema Corporativo`} moduloActual="Permisos-Perfil">
  <div class="page-header">
    <div class="header-title">
      <h1><i class="fas fa-key"></i> {pageTitle}</h1>
      <p>Configura el nivel de acceso de cada perfil a los diferentes módulos</p>
    </div>
    <button class="btn-add" id="btnNuevoPermiso" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-shield-alt"></i> Asignar Permisos
    </button>
  </div>

  <div class="card-container">
    <div class="table-toolbar">
      <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por módulo o perfil...">
      </div>
    </div>

    <div class="table-responsive">
      <table class="crud-table" id="tablaPermisos">
        <thead>
          <tr>
            <th>ID</th>
            <th>Módulo</th>
            <th>Perfil</th>
            <th class="text-center" title="Consulta">C</th> 
            <th class="text-center" title="Agregar">A</th> 
            <th class="text-center" title="Editar">E</th> 
            <th class="text-center" title="Detalle">D</th> 
            <th class="text-center" title="Eliminar">X</th> 
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="tablaBody">
          <tr>
            <td colspan="9" class="no-data">
              <div class="loader-container">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Cargando matriz de permisos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div id="pagination" class="pagination"></div>
  </div>

  <div id="modalPermiso" class="modal" style="display: none;">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Permiso</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="permisoForm" onsubmit="event.preventDefault(); guardarPermiso();">
        <input type="hidden" id="permisoId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Módulo *</label>
            <div class="select-wrapper">
              <select id="idModulo" required>
                <option value="">Seleccione módulo...</option>
              </select>
              <i class="fas fa-chevron-down select-icon"></i>
            </div>
          </div>
          
          <div class="form-group">
            <label>Perfil *</label>
            <div class="select-wrapper">
              <select id="idPerfil" required>
                <option value="">Seleccione perfil...</option>
              </select>
              <i class="fas fa-chevron-down select-icon"></i>
            </div>
          </div>
        </div>

        <div class="permisos-section-title">
          <i class="fas fa-sliders-h"></i> Nivel de Acceso y Privilegios
        </div>
        
        <div class="permisos-grid">
          <label class="permiso-item">
            <input type="checkbox" id="bitConsulta"> 
            <span class="checkmark check-blue"></span> 
            <div class="permiso-text">
              <span class="p-title">Consultar</span>
              <span class="p-desc">Ver listas de datos</span>
            </div>
          </label>
          
          <label class="permiso-item">
            <input type="checkbox" id="bitAgregar"> 
            <span class="checkmark check-green"></span> 
            <div class="permiso-text">
              <span class="p-title">Agregar</span>
              <span class="p-desc">Crear nuevos registros</span>
            </div>
          </label>
          
          <label class="permiso-item">
            <input type="checkbox" id="bitEditar"> 
            <span class="checkmark check-yellow"></span> 
            <div class="permiso-text">
              <span class="p-title">Editar</span>
              <span class="p-desc">Modificar existentes</span>
            </div>
          </label>
          
          <label class="permiso-item">
            <input type="checkbox" id="bitDetalle"> 
            <span class="checkmark check-purple"></span> 
            <div class="permiso-text">
              <span class="p-title">Ver Detalle</span>
              <span class="p-desc">Información completa</span>
            </div>
          </label>
          
          <label class="permiso-item permiso-danger">
            <input type="checkbox" id="bitEliminar"> 
            <span class="checkmark check-red"></span> 
            <div class="permiso-text">
              <span class="p-title">Eliminar</span>
              <span class="p-desc">Borrar del sistema</span>
            </div>
          </label>
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Guardar Permisos</button>
        </div>
      </form>
    </div>
  </div>

  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  const { permisos } = verificarPermisosModulo('Permisos-Perfil');

  // --- VARIABLES ESTÁTICAS PARA PAGINACIÓN Y BÚSQUEDA ---
  let permisosLocales = []; 
  let permisosFiltrados = []; 
  let paginaActual = 1;
  const limitePorPagina = 5; 

  async function cargarSelects() {
    try {
      const token = localStorage.getItem('token');
      const [modulosRes, perfilesRes] = await Promise.all([
        fetch(`${API_URL}/api/modulos-lista`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API_URL}/api/perfiles-lista`, { headers: { 'Authorization': `Bearer ${token}` } })
      ]);
      
      const modulosData = await modulosRes.json();
      const perfilesData = await perfilesRes.json();
      
      if (modulosData.success) {
        document.getElementById('idModulo').innerHTML = '<option value="">Seleccione módulo...</option>' + 
          modulosData.data.map(m => `<option value="${m.id}">${m.strnombremodulo}</option>`).join('');
      }
      
      if (perfilesData.success) {
        document.getElementById('idPerfil').innerHTML = '<option value="">Seleccione perfil...</option>' + 
          perfilesData.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
      }
    } catch (error) { console.error('Error cargando selects:', error); }
  }

  // ============================================
  // CARGA ESTÁTICA TOTAL Y BÚSQUEDA INSTANTÁNEA
  // ============================================
  async function cargarTodosLosPermisos() {
    if (!permisos.consulta) {
      document.getElementById('tablaBody').innerHTML = '<tr><td colspan="9" class="no-data" style="color: #ef4444; font-weight: 600;">❌ No tienes permisos para consultar información.</td></tr>';
      return;
    }
    
    try {
      const token = localStorage.getItem('token');
      let res = await fetch(`${API_URL}/api/permisos-perfil?page=1`, { headers: { 'Authorization': `Bearer ${token}` } });
      let data = await res.json();
      
      if (data.success) {
        let totalPages = data.pagination.totalPages;
        let todos = [...data.data];
        
        if (totalPages > 1) {
          let promesas = [];
          for (let i = 2; i <= totalPages; i++) {
            promesas.push(fetch(`${API_URL}/api/permisos-perfil?page=${i}`, { headers: { 'Authorization': `Bearer ${token}` } }).then(r => r.json()));
          }
          let extras = await Promise.all(promesas);
          extras.forEach(p => { if (p.success) todos.push(...p.data); });
        }
        
        permisosLocales = todos;
        aplicarFiltroInstantaneo();
      }
    } catch (error) { 
      mostrarMensaje('Error al cargar permisos', 'error'); 
    } 
  }

  function aplicarFiltroInstantaneo() {
    const termino = document.getElementById('searchInput').value.toLowerCase();
    
    permisosFiltrados = permisosLocales.filter(p => 
      p.strnombremodulo.toLowerCase().includes(termino) ||
      p.strnombreperfil.toLowerCase().includes(termino)
    );

    paginaActual = 1;
    dibujarVistaEstatica();
  }

  function dibujarVistaEstatica() {
    const inicio = (paginaActual - 1) * limitePorPagina;
    const fin = inicio + limitePorPagina;
    const permisosPagina = permisosFiltrados.slice(inicio, fin);
    
    renderizarTablaHTML(permisosPagina);
    
    const totalPaginas = Math.ceil(permisosFiltrados.length / limitePorPagina);
    renderizarPaginacionHTML(totalPaginas);
  }

  window.cambiarPagina = (numPagina) => {
    paginaActual = numPagina;
    dibujarVistaEstatica();
  };

  // ============================================
  // RENDERIZADO DE INTERFAZ
  // ============================================
  function renderizarTablaHTML(listaPermisos) {
    const tbody = document.getElementById('tablaBody');
    if (!tbody) return;
    
    if (listaPermisos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" class="no-data"><i class="fas fa-folder-open" style="font-size: 2rem; display:block; margin-bottom:10px;"></i> No se encontraron permisos.</td></tr>';
      return;
    }
    
    const iconCheck = '<div class="check-badge true"><i class="fas fa-check"></i></div>';
    const iconCross = '<div class="check-badge false"><i class="fas fa-times"></i></div>';

    tbody.innerHTML = listaPermisos.map(p => `
      <tr>
        <td style="vertical-align: middle; color: #64748b; font-weight: 600;">#${p.id}</td>
        <td style="vertical-align: middle; font-weight: 700; color: #1e293b;">
          <div style="display:flex; align-items:center; gap:8px;">
            <div style="width:30px; height:30px; border-radius:6px; background:#eff6ff; display:flex; align-items:center; justify-content:center; color:#3b82f6;">
              <i class="fas fa-box"></i>
            </div>
            ${p.strnombremodulo}
          </div>
        </td>
        <td style="vertical-align: middle;">
          <span class="role-badge"><i class="fas fa-id-badge"></i> ${p.strnombreperfil}</span>
        </td>
        <td class="text-center" style="vertical-align: middle;">${p.bitconsulta ? iconCheck : iconCross}</td>
        <td class="text-center" style="vertical-align: middle;">${p.bitagregar ? iconCheck : iconCross}</td>
        <td class="text-center" style="vertical-align: middle;">${p.biteditar ? iconCheck : iconCross}</td>
        <td class="text-center" style="vertical-align: middle;">${p.bitdetalle ? iconCheck : iconCross}</td>
        <td class="text-center" style="vertical-align: middle;">${p.biteliminar ? iconCheck : iconCross}</td>
        <td class="actions-cell" style="vertical-align: middle;">
          ${permisos.detalle ? `<button class="action-btn view" onclick="verDetalle(${p.id})" title="Ver Detalles"><i class="fas fa-list-ul"></i></button>` : ''}
          ${permisos.editar ? `<button class="action-btn edit" onclick="editarPermiso(${p.id})" title="Editar"><i class="fas fa-pen"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="action-btn delete" onclick="eliminarPermiso(${p.id})" title="Eliminar"><i class="fas fa-trash-alt"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacionHTML(totalPages) {
    const div = document.getElementById('pagination');
    if (totalPages <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    for (let i = 1; i <= totalPages; i++) {
      html += `<button class="page-btn ${i === paginaActual ? 'active' : ''}" onclick="window.cambiarPagina(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  // ============================================
  // FUNCIONES DE MODAL Y CRUD
  // ============================================
  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Configurar Permisos';
    const form = document.getElementById('permisoForm') as HTMLFormElement;
    if(form) form.reset();
    document.getElementById('permisoId').value = '';
    document.getElementById('modalPermiso').style.display = 'flex';
  };

  window.cerrarModal = () => { document.getElementById('modalPermiso').style.display = 'none'; };

  window.editarPermiso = async (id) => {
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await res.json();
    if (data.success) {
      const p = data.data;
      document.getElementById('modalTitulo').textContent = 'Modificar Permisos';
      (document.getElementById('permisoId') as HTMLInputElement).value = p.id;
      (document.getElementById('idModulo') as HTMLSelectElement).value = p.idmodulo;
      (document.getElementById('idPerfil') as HTMLSelectElement).value = p.idperfil;
      (document.getElementById('bitAgregar') as HTMLInputElement).checked = p.bitagregar;
      (document.getElementById('bitEditar') as HTMLInputElement).checked = p.biteditar;
      (document.getElementById('bitConsulta') as HTMLInputElement).checked = p.bitconsulta;
      (document.getElementById('bitEliminar') as HTMLInputElement).checked = p.biteliminar;
      (document.getElementById('bitDetalle') as HTMLInputElement).checked = p.bitdetalle;
      document.getElementById('modalPermiso').style.display = 'flex';
    }
  };

  window.verDetalle = async (id) => {
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await res.json();
    if (data.success) {
      const p = data.data;
      alert(`Matriz de Acceso:\n\nMódulo: ${p.strnombremodulo}\nPerfil: ${p.strnombreperfil}\n\nPermisos Otorgados:\n- Consultar: ${p.bitconsulta ? 'SÍ':'NO'}\n- Agregar: ${p.bitagregar ? 'SÍ':'NO'}\n- Editar: ${p.biteditar ? 'SÍ':'NO'}\n- Detalle: ${p.bitdetalle ? 'SÍ':'NO'}\n- Eliminar: ${p.biteliminar ? 'SÍ':'NO'}`);
    }
  };

  window.guardarPermiso = async () => {
    const id = (document.getElementById('permisoId') as HTMLInputElement).value;
    const permisoData = {
      idModulo: parseInt((document.getElementById('idModulo') as HTMLSelectElement).value),
      idPerfil: parseInt((document.getElementById('idPerfil') as HTMLSelectElement).value),
      bitAgregar: (document.getElementById('bitAgregar') as HTMLInputElement).checked,
      bitEditar: (document.getElementById('bitEditar') as HTMLInputElement).checked,
      bitConsulta: (document.getElementById('bitConsulta') as HTMLInputElement).checked,
      bitEliminar: (document.getElementById('bitEliminar') as HTMLInputElement).checked,
      bitDetalle: (document.getElementById('bitDetalle') as HTMLInputElement).checked
    };
    
    const token = localStorage.getItem('token');
    const response = await fetch(id ? `${API_URL}/api/permisos-perfil/${id}` : `${API_URL}/api/permisos-perfil`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(permisoData)
    });
    
    const data = await response.json();
    if (data.success) {
      mostrarMensaje(id ? 'Permisos actualizados' : 'Permisos creados', 'success');
      cerrarModal();
      cargarTodosLosPermisos();
    } else {
      mostrarMensaje(data.message || 'Error al guardar', 'error');
    }
  };

  window.eliminarPermiso = async (id) => {
    if (!confirm('¿Revocar completamente el acceso a este módulo para este perfil?')) return;
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    if ((await res.json()).success) {
        mostrarMensaje('Acceso revocado', 'success');
        cargarTodosLosPermisos();
    }
  };

  function mostrarMensaje(texto, tipo) {
    const msj = document.getElementById('message');
    msj.textContent = texto;
    msj.className = `status-message msg-${tipo}`;
    msj.style.display = 'block';
    setTimeout(() => { msj.style.display = 'none'; }, 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) {
        const btn = document.getElementById('btnNuevoPermiso');
        if(btn) btn.style.display = 'flex';
    }
    
    document.getElementById('searchInput').addEventListener('input', aplicarFiltroInstantaneo);
    
    cargarSelects();
    cargarTodosLosPermisos();
  });
</script>

<style is:global>
  /* --- CABECERA --- */
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .header-title h1 { margin: 0; color: #0f172a; font-size: 1.8rem; display: flex; align-items: center; gap: 10px; }
  .header-title p { margin: 5px 0 0 0; color: #64748b; font-size: 0.95rem; }
  
  .btn-add { background: #2563eb; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 8px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2); transition: all 0.2s; }
  .btn-add:hover { background: #1d4ed8; transform: translateY(-2px); }

  /* --- TARJETA Y BUSCADOR --- */
  .card-container { background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); padding: 1.5rem; border: 1px solid #f1f5f9; }
  
  .table-toolbar { margin-bottom: 1.5rem; display: flex; justify-content: flex-end; }
  .search-box { position: relative; width: 100%; max-width: 400px; }
  .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1.1rem; }
  .search-box input { width: 100%; padding: 0.9rem 1rem 0.9rem 2.8rem; border: 2px solid #e2e8f0; border-radius: 30px; font-size: 0.95rem; transition: border-color 0.2s; background: #f8fafc; color: #334155; }
  .search-box input:focus { outline: none; border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }

  /* --- TABLA --- */
  .table-responsive { overflow-x: auto; }
  .crud-table { width: 100%; border-collapse: collapse; min-width: 800px; }
  .crud-table th { text-align: left; padding: 1rem 0.5rem; color: #475569; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; background: white; }
  .crud-table tbody tr { transition: background-color 0.2s; border-bottom: 1px solid #f1f5f9; }
  .crud-table tbody tr:hover { background-color: #f8fafc; }
  .text-center { text-align: center !important; }
  .no-data { text-align: center; color: #94a3b8; padding: 3rem !important; }
  
  /* Iconos de check en tabla */
  .check-badge { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; margin: 0 auto; }
  .check-badge.true { background: #dcfce7; color: #10b981; }
  .check-badge.false { background: #f1f5f9; color: #cbd5e1; }

  /* --- ESTILOS VISUALES CELDAS --- */
  .role-badge { display: inline-flex; align-items: center; gap: 8px; background: white; color: #334155; padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; border: 1px solid #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);}
  .role-badge i { color: #6366f1; }

  /* --- BOTONES DE ACCIÓN --- */
  .actions-cell { display: flex; gap: 8px; justify-content: flex-start; }
  .action-btn { width: 35px; height: 35px; border-radius: 8px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; font-size: 1rem; }
  .action-btn.view { background: #f8fafc; color: #475569; border: 1px solid #e2e8f0; }
  .action-btn.view:hover { background: #475569; color: white; border-color: #475569; }
  .action-btn.edit { background: #eff6ff; color: #3b82f6; border: 1px solid #bfdbfe; }
  .action-btn.edit:hover { background: #3b82f6; color: white; }
  .action-btn.delete { background: #fef2f2; color: #ef4444; border: 1px solid #fecaca; }
  .action-btn.delete:hover { background: #ef4444; color: white; }

  /* --- PAGINACIÓN ESTÁTICA --- */
  .pagination { display: flex; justify-content: center; gap: 8px; margin-top: 2rem; }
  .page-btn { width: 35px; height: 35px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; color: #475569; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
  .page-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
  .page-btn.active { background: #2563eb; color: white; border-color: #2563eb; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); }

  /* --- MODAL FORMULARIO Y SELECTS MODERNOS --- */
  .modal { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
  .modal-content { background: white; padding: 2rem; border-radius: 16px; width: 100%; max-width: 650px; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
  .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 1rem; }
  .modal-header h3 { margin: 0; color: #0f172a; font-size: 1.4rem; }
  .close-btn { background: #f1f5f9; border: none; width: 35px; height: 35px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; color: #64748b; transition: all 0.2s; }
  .close-btn:hover { background: #fee2e2; color: #ef4444; }
  
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 2rem; }
  .form-group { display: flex; flex-direction: column; }
  .form-group label { font-weight: 700; margin-bottom: 0.5rem; color: #334155; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;}
  
  .select-wrapper { position: relative; }
  .select-icon { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none; }
  .select-wrapper select { width: 100%; padding: 0.9rem; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; font-weight: 500; color: #1e293b; transition: all 0.2s; cursor: pointer; background: #f8fafc; appearance: none; -webkit-appearance: none; }
  .select-wrapper select:focus { outline: none; border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);}

  /* --- CHECKBOXES COMO TARJETAS (NUEVO DISEÑO) --- */
  .permisos-section-title { font-weight: 700; color: #334155; font-size: 1.1rem; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center; gap: 8px;}
  .permisos-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; }
  
