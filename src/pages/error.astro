---
import Layout from '../layout/layout.astro';

interface Props {
  code?: number;
  message?: string;
}

const { code = 404, message = 'Página no encontrada' } = Astro.props;
---

<Layout title={`Error | Sistema Corporativo`}>
  <div class="error-container">
    <div class="error-code" id="display-code">{code}</div>
    <h1 id="display-message">{message}</h1>
    <p>Lo sentimos, ha ocurrido un evento que impide continuar en este módulo.</p>
    
    <div class="error-actions">
      <a href="/extra-earth/principal1/estatico1" class="btn btn-primary">
        <i class="fas fa-home"></i> Volver al Inicio
      </a>
      <button class="btn btn-outline" onclick="window.history.back()">
        <i class="fas fa-arrow-left"></i> Regresar
      </button>
    </div>
  </div>
</Layout>

<script>
  // LEER PARÁMETROS DE LA URL (Para captar el 403 de falta de permisos)
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');
    const msg = params.get('message') || params.get('msg');

    if (code) {
      const codeEl = document.getElementById('display-code');
      if (codeEl) codeEl.textContent = code;
    }
    if (msg) {
      const msgEl = document.getElementById('display-message');
      if (msgEl) msgEl.textContent = decodeURIComponent(msg);
    }
  });
</script>

<style>
  /* Tus estilos están excelentes, se mantienen igual */
  .error-container { text-align: center; padding: 5rem 1rem; max-width: 500px; margin: 0 auto; }
  .error-code { font-size: 6rem; font-weight: 800; color: #ef4444; line-height: 1; margin-bottom: 1rem; text-shadow: 4px 4px 0 #fee2e2; }
  h1 { font-size: 1.75rem; color: #1e293b; margin-bottom: 1rem; }
  p { color: #64748b; margin-bottom: 2rem; }
  .error-actions { display: flex; gap: 1rem; justify-content: center; }
  .btn { padding: 0.75rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; border: none; cursor: pointer; }
  .btn-primary { background: #1e293b; color: white; }
  .btn-outline { background: white; border: 1px solid #e2e8f0; color: #334155; }
  @media (max-width: 640px) { .error-actions { flex-direction: column; } .error-code { font-size: 4rem; } }
</style>