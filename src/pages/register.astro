---
import Layout from '../layout/layout.astro';
// En producción, lo ideal es usar import.meta.env.PUBLIC_API_URL
// Pero mantendremos tu constante para no romper tu flujo actual.
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Registro de Usuario | Sistema Corporativo">
  <div class="register-card">
    <div class="register-header">
      <i class="fas fa-user-plus"></i>
      <h2>Crear Cuenta</h2>
      <p>Regístrese para acceder a la plataforma</p>
    </div>

    <form id="registerForm" data-api-url={API_URL}>

      <div class="input-group">
        <label for="username">Usuario *</label>
        <div class="input-wrapper">
          <i class="fas fa-at"></i>
          <input type="text" id="username" name="username" placeholder="usuario123" required maxlength="100">
        </div>
      </div>

      <div class="input-group">
        <label for="nombre">Nombre Completo *</label>
        <div class="input-wrapper">
          <i class="fas fa-user-tag"></i>
          <input type="text" id="nombre" name="nombre" placeholder="Juan Pérez" required>
        </div>
      </div>

      <div class="input-group">
        <label for="email">Correo Electrónico *</label>
        <div class="input-wrapper">
          <i class="fas fa-envelope"></i>
          <input type="email" id="email" name="email" placeholder="correo@corporativo.com" required>
        </div>
      </div>

      <div class="input-group">
        <label for="password">Contraseña *</label>
        <div class="input-wrapper">
          <i class="fas fa-lock"></i>
          <input type="password" id="password" name="password" placeholder="Mínimo 6 caracteres" required minlength="6">
        </div>
        <small class="field-hint">Mínimo 6 caracteres</small>
      </div>

      <div class="input-group">
        <label for="confirmPwd">Confirmar Contraseña *</label>
        <div class="input-wrapper">
          <i class="fas fa-lock"></i>
          <input type="password" id="confirmPwd" name="confirmPwd" placeholder="Repita su contraseña" required>
        </div>
      </div>

      <button type="submit" id="btnRegister">
        <span>Finalizar Registro</span>
        <i class="fas fa-check-circle"></i>
      </button>

    </form>

    <div id="message" class="status-message"></div>

    <div class="register-footer">
      ¿Ya tiene una cuenta? <a href="/extra-earth/login">Inicie sesión aquí</a>
    </div>
  </div>
</Layout>

<style>
.register-card { max-width: 500px; margin: 2rem auto; padding: 1rem; }
.register-header { text-align: center; margin-bottom: 2rem; }
.register-header i { font-size: 3rem; color: #10b981; margin-bottom: 1rem; }
.register-header h2 { font-size: 1.75rem; color: #1e293b; margin: 0; }
.register-header p { color: #64748b; font-size: 0.9rem; }
.input-group { margin-bottom: 1.25rem; }
.input-group label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; color: #475569; }
.field-hint { display: block; font-size: 0.75rem; color: #94a3b8; margin-top: 0.25rem; }
.input-wrapper { position: relative; display: flex; align-items: center; }
.input-wrapper i { position: absolute; left: 1rem; color: #94a3b8; }
.input-wrapper input { width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.95rem; transition: all .2s; }
.input-wrapper input:focus { outline: none; border-color: #10b981; box-shadow: 0 0 0 3px rgba(16, 185, 129, .1); }
button { width: 100%; padding: 0.9rem; background: #059669; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 1rem; }
button:hover { background: #047857; }
button:disabled { background: #94a3b8; cursor: not-allowed; }
.status-message { margin-top: 1.5rem; padding: 0.8rem; border-radius: 6px; font-size: 0.9rem; display: none; text-align: center; }
.register-footer { text-align: center; margin-top: 2rem; font-size: 0.85rem; color: #64748b; }
.register-footer a { color: #059669; text-decoration: none; font-weight: 600; }
</style>

<script>
  // Astro v5: Usamos el tag script normal. Astro lo procesará, minificará y agrupará.
  // Envolvemos todo en una función para asegurar que el DOM esté listo
  const setupRegisterForm = () => {
    const form = document.getElementById('registerForm') as HTMLFormElement;
    
    // Si el formulario no está en la página actual (útil si usas ViewTransitions), salimos
    if (!form) return;

    const messageDiv = document.getElementById('message');
    const btnRegister = document.getElementById('btnRegister') as HTMLButtonElement;
    
    // Recuperamos la URL que inyectamos desde Astro
    const apiUrl = form.dataset.apiUrl;

    // Función auxiliar para mensajes
    const showMsg = (text, type) => {
      if (!messageDiv) return;
      messageDiv.style.display = 'block';
      messageDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
      messageDiv.style.color = type === 'success' ? '#166534' : '#991b1b';
      messageDiv.textContent = text;

      setTimeout(() => {
        messageDiv.style.display = 'none';
      }, 5000);
    };

    // Usamos onsubmit en lugar de addEventListener para evitar duplicaciones
    // si la página se recarga o se navega por cliente
    form.onsubmit = async (e) => {
      e.preventDefault();

      const username = (document.getElementById('username') as HTMLInputElement).value.trim();
      const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPwd = (document.getElementById('confirmPwd') as HTMLInputElement).value;

      if (!username || !nombre || !email || !password) {
        showMsg('Todos los campos son obligatorios', 'error');
        return;
      }

      if (password.length < 6) {
        showMsg('La contraseña debe tener al menos 6 caracteres', 'error');
        return;
      }

      if (password !== confirmPwd) {
        showMsg('Las contraseñas no coinciden', 'error');
        return;
      }

      btnRegister.disabled = true;
      btnRegister.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Procesando...';

      try {
        const response = await fetch(`${apiUrl}/api/register`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            username,
            email,
            nombre,
            password
          })
        });

        const data = await response.json();

        if (data.success) {
          showMsg('✅ Registro exitoso. Redirigiendo al login...', 'success');
          // Redirección segura
          setTimeout(() => {
            window.location.href = "/extra-earth/login";
          }, 2000);
        } else {
          showMsg(data.message || 'Error al registrar', 'error');
          // Restauramos el botón solo si hubo error
          btnRegister.disabled = false;
          btnRegister.innerHTML = '<span>Finalizar Registro</span><i class="fas fa-check-circle"></i>';
        }
      } catch (err) {
        console.error('Fetch error:', err);
        showMsg('Error de conexión con el servidor', 'error');
        btnRegister.disabled = false;
        btnRegister.innerHTML = '<span>Finalizar Registro</span><i class="fas fa-check-circle"></i>';
      }
    };
  };

  // Inicialización estándar
  document.addEventListener('DOMContentLoaded', setupRegisterForm);
  
  // Soporte para Astro View Transitions (si decides usarlas)
  document.addEventListener('astro:page-load', setupRegisterForm);
</script>