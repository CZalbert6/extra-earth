---
// src/pages/modulos/usuarios.astro
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Gestión de Usuarios" moduloActual="Usuario">
  <div class="page-header">
    <div class="header-title">
      <h1><i class="fas fa-users"></i> Gestión de Usuarios</h1>
      <p>Administra los accesos y roles del personal del sistema</p>
    </div>
    <button class="btn-add" id="btnNuevoUsuario" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-user-plus"></i> Nuevo Usuario
    </button>
  </div>

  <div class="card-container">
    <div class="table-toolbar">
      <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por nombre, usuario, correo o perfil...">
      </div>
    </div>

    <div class="table-responsive">
      <table class="crud-table" id="tablaUsuarios">
        <thead>
          <tr>
            <th style="display: none;">ID</th>
            <th>Foto</th>
            <th>Usuario</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Perfil</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="tablaBody">
          <tr>
            <td colspan="8" class="no-data">
              <i class="fas fa-spinner fa-spin"></i> Cargando usuarios...
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div id="pagination" class="pagination"></div>
  </div>

  <div id="modalUsuario" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Usuario</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="usuarioForm" onsubmit="event.preventDefault(); guardarUsuario();">
        <input type="hidden" id="usuarioId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Usuario *</label>
            <input type="text" id="username" required maxlength="100" placeholder="Ej. jperez">
          </div>
          
          <div class="form-group">
            <label>Nombre Completo *</label>
            <input type="text" id="nombre" required placeholder="Ej. Juan Pérez">
          </div>

          <div class="form-group">
            <label>Correo *</label>
            <input type="email" id="email" required placeholder="correo@empresa.com">
          </div>
          
          <div class="form-group">
            <label>Teléfono</label>
            <input type="text" id="strNumeroCelular" placeholder="10 dígitos">
          </div>
          
          <div class="form-group">
            <label>Perfil</label>
            <select id="idPerfil">
              <option value="">Seleccione...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Estado</label>
            <select id="idEstadoUsuario">
              <option value="1">Activo</option>
              <option value="0">Inactivo</option>
            </select>
          </div>
          
          <div class="form-group" style="grid-column: span 2;">
            <label>Contraseña</label>
            <input type="password" id="password" minlength="6" placeholder="••••••••">
            <small>Mínimo 6 caracteres. Dejar vacío para no cambiar en edición.</small>
          </div>
        </div>
        
        <div class="form-group imagen-group">
          <label>Foto de Perfil</label>
          <div class="imagen-preview" id="imagenPreview">
            <img id="previewImg" src="#" alt="Vista previa" style="display: none; width: 120px; height: 120px; object-fit: cover; border-radius: 50%;">
            <div class="preview-placeholder" id="previewPlaceholder">
              <i class="fas fa-camera"></i>
            </div>
          </div>
          
          <div class="imagen-input" style="text-align: center;">
            <input type="file" id="imagenFile" accept="image/jpeg,image/png,image/gif" onchange="previsualizarImagen(event)" style="display: none;">
            <button type="button" class="btn-secondary btn-upload" onclick="document.getElementById('imagenFile').click()">
              <i class="fas fa-upload"></i> Seleccionar Imagen
            </button>
            <button type="button" class="btn-clear" onclick="limpiarImagen()" style="display: none; background: #fee2e2; color: #ef4444; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; margin-top: 5px; font-weight: 600;" id="btnClearImagen">
              <i class="fas fa-trash-alt"></i> Quitar
            </button>
          </div>
          <input type="hidden" id="strImagenBase64">
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Guardar Usuario</button>
        </div>
      </form>
    </div>
  </div>

  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  const { permisos } = verificarPermisosModulo('Usuario');

  // --- VARIABLES PARA EL MODO ESTÁTICO (Frontend Paginación y Búsqueda) ---
  let usuariosLocales = []; 
  let usuariosFiltrados = []; 
  let paginaActual = 1;
  const limitePorPagina = 5; 

  // ============================================
  // MOTOR DE COMPRESIÓN EXTREMA DE IMÁGENES
  // ============================================
  window.previsualizarImagen = (event) => {
    const file = event.target.files[0];
    if (!file) return;

    if (!file.type.match('image.*')) {
      alert('Por favor, seleccione una imagen válida');
      event.target.value = '';
      return;
    }

    if (file.size > 2 * 1024 * 1024) {
      alert('La imagen es muy pesada. Máximo 2MB.');
      event.target.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.src = e.target.result;
      
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let width = img.width;
        let height = img.height;
        
        const MAX_SIZE = 200;
        
        if (width > height && width > MAX_SIZE) {
          height = Math.round((height * MAX_SIZE) / width);
          width = MAX_SIZE;
        } else if (height > MAX_SIZE) {
          width = Math.round((width * MAX_SIZE) / height);
          height = MAX_SIZE;
        }
        
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);
        
        let compressedBase64 = canvas.toDataURL('image/jpeg', 0.4); // Balance calidad/peso
        
        document.getElementById('strImagenBase64').value = compressedBase64;
        
        const previewImg = document.getElementById('previewImg');
        previewImg.src = compressedBase64;
        previewImg.style.display = 'block';
        
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      };
    };
    reader.readAsDataURL(file);
  };

  window.limpiarImagen = () => {
    document.getElementById('imagenFile').value = '';
    document.getElementById('strImagenBase64').value = '';
    
    const previewImg = document.getElementById('previewImg');
    previewImg.style.display = 'none';
    previewImg.src = '#'; 
    
    document.getElementById('previewPlaceholder').style.display = 'flex';
    document.getElementById('btnClearImagen').style.display = 'none';
  };

  async function cargarPerfiles() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/perfiles-lista`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      const select = document.getElementById('idPerfil');
      select.innerHTML = '<option value="">Seleccione...</option>' + 
        data.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
    }
  }

  // ============================================
  // CARGA ESTÁTICA TOTAL Y BÚSQUEDA INSTANTÁNEA
  // ============================================
  async function cargarTodosLosUsuarios() {
    if (!permisos.consulta) {
      document.getElementById('tablaBody').innerHTML = '<tr><td colspan="8" class="no-data" style="color: #ef4444;">❌ No tienes permisos para consultar información.</td></tr>';
      return;
    }

    try {
      const token = localStorage.getItem('token');
      // 1. Pedimos la página 1 para saber cuántas páginas hay en total
      let res = await fetch(`${API_URL}/api/usuarios?page=1`, { headers: { 'Authorization': `Bearer ${token}` } });
      let data = await res.json();
      
      if (data.success) {
        let totalPages = data.pagination.totalPages;
        let todos = [...data.data];
        
        // 2. Si hay más páginas, las descargamos todas de golpe en segundo plano
        if (totalPages > 1) {
          let promesas = [];
          for (let i = 2; i <= totalPages; i++) {
            promesas.push(fetch(`${API_URL}/api/usuarios?page=${i}`, { headers: { 'Authorization': `Bearer ${token}` } }).then(r => r.json()));
          }
          let extras = await Promise.all(promesas);
          extras.forEach(p => { if (p.success) todos.push(...p.data); });
        }
        
        // Guardamos todo en memoria
        usuariosLocales = todos;
        aplicarFiltroInstantaneo(); // Aplica la búsqueda si hay algo escrito y dibuja la tabla
      }
    } catch (error) {
      console.error(error);
      mostrarMensaje('Error de conexión al cargar la tabla', 'error');
    }
  }

  // Se activa cada vez que el usuario presiona una tecla
  function aplicarFiltroInstantaneo() {
    const termino = document.getElementById('searchInput').value.toLowerCase();
    
    usuariosFiltrados = usuariosLocales.filter(u => 
      u.nombre.toLowerCase().includes(termino) ||
      u.username.toLowerCase().includes(termino) ||
      u.email.toLowerCase().includes(termino) ||
      (u.strnombreperfil && u.strnombreperfil.toLowerCase().includes(termino))
    );

    // Regresamos a la página 1 después de buscar
    paginaActual = 1;
    dibujarVistaEstatica();
  }

  // Dibuja solo los 5 usuarios que corresponden a la página actual en memoria
  function dibujarVistaEstatica() {
    const inicio = (paginaActual - 1) * limitePorPagina;
    const fin = inicio + limitePorPagina;
    const usuariosPagina = usuariosFiltrados.slice(inicio, fin);
    
    renderizarTablaHTML(usuariosPagina);
    
    const totalPaginas = Math.ceil(usuariosFiltrados.length / limitePorPagina);
    renderizarPaginacionHTML(totalPaginas);
  }

  window.cambiarPagina = (numPagina) => {
    paginaActual = numPagina;
    dibujarVistaEstatica();
  };

  // ============================================
  // RENDERIZADO DE INTERFAZ
  // ============================================
  function renderizarTablaHTML(usuarios) {
    const tbody = document.getElementById('tablaBody');
    
    if (usuarios.length === 0) {
      tbody.innerHTML = `<tr><td colspan="8" class="no-data"><i class="fas fa-search-minus"></i> No se encontraron usuarios.</td></tr>`;
      return;
    }

    tbody.innerHTML = usuarios.map(u => `
      <tr>
        <td style="display: none; vertical-align: middle; padding: 1rem 0.5rem; color: #64748b; font-weight: 500;">#${u.id}</td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem;">
          <div class="avatar-container">
            <img src="${u.strimagen || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(u.nombre) + '&size=45&background=f1f5f9&color=64748b'}" 
                 class="avatar-img" 
                 alt="Avatar"
                 onerror="this.src='https://ui-avatars.com/api/?name=U&size=45'">
          </div>
        </td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem; font-weight: 600; color: #1e293b;">@${u.username}</td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem;">${u.nombre}</td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem; color: #64748b;">${u.email}</td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem;">
          <span class="role-badge"><i class="fas fa-shield-alt"></i> ${u.strnombreperfil || 'Sin perfil'}</span>
        </td>
        <td style="vertical-align: middle; padding: 1rem 0.5rem;">
          <span class="status-badge ${u.idestadousuario === 1 ? 'status-active' : 'status-inactive'}">
            ${u.idestadousuario === 1 ? 'Activo' : 'Inactivo'}
          </span>
        </td>
        <td class="actions-cell" style="vertical-align: middle; padding: 1rem 0.5rem;">
          ${permisos.detalle ? `<button class="action-btn view" onclick="verDetalle(${u.id})" title="Ver Detalles"><i class="fas fa-eye"></i></button>` : ''}
          ${permisos.editar ? `<button class="action-btn edit" onclick="editarUsuario(${u.id})" title="Editar"><i class="fas fa-edit"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="action-btn delete" onclick="eliminarUsuario(${u.id})" title="Eliminar"><i class="fas fa-trash"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacionHTML(totalPages) {
    const div = document.getElementById('pagination');
    if (totalPages <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    for (let i = 1; i <= totalPages; i++) {
      html += `<button class="page-btn ${i === paginaActual ? 'active' : ''}" onclick="window.cambiarPagina(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  // ============================================
  // FUNCIONES DE MODAL Y CRUD
  // ============================================
  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Nuevo Usuario';
    document.getElementById('usuarioForm').reset();
    document.getElementById('usuarioId').value = '';
    document.getElementById('password').required = true;
    limpiarImagen();
    document.getElementById('modalUsuario').style.display = 'flex';
  };

  window.cerrarModal = () => { document.getElementById('modalUsuario').style.display = 'none'; };

  window.verDetalle = async (id) => {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/usuarios/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await response.json();
    if (data.success) {
      const u = data.data;
      alert(`Información de Sistema:\n\nUsuario: ${u.username}\nNombre: ${u.nombre}\nEmail: ${u.email}\nTeléfono: ${u.strnumerocelular || 'N/A'}\nEstado: ${u.idestadousuario === 1 ? 'Activo' : 'Inactivo'}`);
    }
  };

  window.editarUsuario = async (id) => {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/usuarios/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await response.json();
    if (data.success) {
      const u = data.data;
      document.getElementById('modalTitulo').textContent = 'Editar Usuario';
      document.getElementById('usuarioId').value = u.id;
      document.getElementById('username').value = u.username;
      document.getElementById('nombre').value = u.nombre;
      document.getElementById('email').value = u.email;
      document.getElementById('strNumeroCelular').value = u.strnumerocelular || '';
      document.getElementById('idPerfil').value = u.idperfil || '';
      document.getElementById('idEstadoUsuario').value = u.idestadousuario;
      document.getElementById('password').required = false;
      document.getElementById('password').value = '';
      
      if (u.strimagen) {
        document.getElementById('strImagenBase64').value = u.strimagen;
        const img = document.getElementById('previewImg');
        img.src = u.strimagen;
        img.style.display = 'block';
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      } else {
        limpiarImagen();
      }
      document.getElementById('modalUsuario').style.display = 'flex';
    }
  };

  window.guardarUsuario = async () => {
    const id = document.getElementById('usuarioId').value;
    const password = document.getElementById('password').value;
    
    const body = {
      username: document.getElementById('username').value,
      nombre: document.getElementById('nombre').value,
      email: document.getElementById('email').value,
      idPerfil: document.getElementById('idPerfil').value || null,
      idEstadoUsuario: parseInt(document.getElementById('idEstadoUsuario').value),
      strNumeroCelular: document.getElementById('strNumeroCelular').value || null,
      strImagenBase64: document.getElementById('strImagenBase64').value || null
    };

    if (password) body.password = password;

    const token = localStorage.getItem('token');
    const response = await fetch(id ? `${API_URL}/api/usuarios/${id}` : `${API_URL}/api/usuarios`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(body)
    });

    const data = await response.json();
    if (data.success) {
      cerrarModal();
      mostrarMensaje(id ? 'Usuario actualizado exitosamente' : 'Usuario creado exitosamente', 'success');
      cargarTodosLosUsuarios(); // Recargamos para traer los datos frescos
    } else {
      mostrarMensaje(data.message || 'Error al guardar usuario', 'error');
    }
  };

  window.eliminarUsuario = async (id) => {
    if (!confirm('¿Está seguro de eliminar permanentemente este usuario?')) return;
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      mostrarMensaje('Usuario eliminado', 'success');
      cargarTodosLosUsuarios();
    }
  };

  function mostrarMensaje(texto, tipo) {
    const msj = document.getElementById('message');
    msj.textContent = texto;
    msj.className = `status-message msg-${tipo}`;
    msj.style.display = 'block';
    setTimeout(() => { msj.style.display = 'none'; }, 3000);
  }

  // ============================================
  // EVENTOS INICIALES
  // ============================================
  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) document.getElementById('btnNuevoUsuario').style.display = 'flex';
    
    // Escuchador de la barra de búsqueda (El Fech instantáneo estático)
    document.getElementById('searchInput').addEventListener('input', aplicarFiltroInstantaneo);
    
    cargarPerfiles();
    cargarTodosLosUsuarios();
  });
</script>

<style is:global>
  /* --- CABECERA --- */
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .header-title h1 { margin: 0; color: #0f172a; font-size: 1.8rem; display: flex; align-items: center; gap: 10px; }
  .header-title p { margin: 5px 0 0 0; color: #64748b; font-size: 0.95rem; }
  
  .btn-add { background: #2563eb; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 8px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2); transition: all 0.2s; }
  .btn-add:hover { background: #1d4ed8; transform: translateY(-2px); }

  /* --- TARJETA Y BUSCADOR --- */
  .card-container { background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); padding: 1.5rem; border: 1px solid #f1f5f9; }
  
  .table-toolbar { margin-bottom: 1.5rem; display: flex; justify-content: flex-end; }
  .search-box { position: relative; width: 100%; max-width: 400px; }
  .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1.1rem; }
  .search-box input { width: 100%; padding: 0.9rem 1rem 0.9rem 2.8rem; border: 2px solid #e2e8f0; border-radius: 30px; font-size: 0.95rem; transition: border-color 0.2s; background: #f8fafc; color: #334155; }
  .search-box input:focus { outline: none; border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }

  /* --- TABLA --- */
  .table-responsive { overflow-x: auto; }
  .crud-table { width: 100%; border-collapse: collapse; min-width: 800px; }
  .crud-table th { text-align: left; padding: 1rem 0.5rem; color: #475569; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; background: white; }
  .crud-table tbody tr { transition: background-color 0.2s; border-bottom: 1px solid #f1f5f9; }
  .crud-table tbody tr:hover { background-color: #f8fafc; }
  .no-data { text-align: center; color: #94a3b8; padding: 3rem !important; font-size: 1.1rem; }

  /* --- ESTILOS VISUALES CELDAS --- */
  .avatar-container { width: 45px; height: 45px; border-radius: 50%; overflow: hidden; background: #f1f5f9; border: 2px solid #e2e8f0; display: flex; align-items: center; justify-content: center; }
  .avatar-img { width: 100%; height: 100%; object-fit: cover; }
  
  .role-badge { display: inline-flex; align-items: center; gap: 5px; background: #f1f5f9; color: #475569; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600; border: 1px solid #e2e8f0; }
  
  .status-badge { padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.8rem; font-weight: 700; display: inline-block; }
  .status-active { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
  .status-inactive { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

  /* --- BOTONES DE ACCIÓN --- */
  .actions-cell { display: flex; gap: 8px; }
  .action-btn { width: 35px; height: 35px; border-radius: 8px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; font-size: 1rem; }
  .action-btn.view { background: #eff6ff; color: #3b82f6; }
  .action-btn.view:hover { background: #3b82f6; color: white; }
  .action-btn.edit { background: #fef3c7; color: #d97706; }
  .action-btn.edit:hover { background: #f59e0b; color: white; }
  .action-btn.delete { background: #fef2f2; color: #ef4444; }
  .action-btn.delete:hover { background: #ef4444; color: white; }

  /* --- PAGINACIÓN ESTÁTICA --- */
  .pagination { display: flex; justify-content: center; gap: 8px; margin-top: 2rem; }
  .page-btn { width: 35px; height: 35px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; color: #475569; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
  .page-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
  .page-btn.active { background: #2563eb; color: white; border-color: #2563eb; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2); }

  /* --- MODAL FORMULARIO --- */
  .modal { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
