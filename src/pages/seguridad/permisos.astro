---
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Gestión de Permisos por Perfil";
---

<Layout title={`${pageTitle} | Sistema Corporativo`} moduloActual="Permisos-Perfil">
  <div class="page-header">
    <h1><i class="fas fa-key"></i> {pageTitle}</h1>
    <button class="btn-add" id="btnNuevoPermiso" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Permiso
    </button>
  </div>

  <div id="modalPermiso" class="modal" style="display: none;">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Permiso</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="permisoForm" onsubmit="event.preventDefault(); guardarPermiso();">
        <input type="hidden" id="permisoId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Módulo *</label>
            <select id="idModulo" required>
              <option value="">Seleccione módulo...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Perfil *</label>
            <select id="idPerfil" required>
              <option value="">Seleccione perfil...</option>
            </select>
          </div>
        </div>

        <div class="permisos-grid">
          <div class="permiso-item">
            <label><input type="checkbox" id="bitAgregar"> Agregar</label>
          </div>
          <div class="permiso-item">
            <label><input type="checkbox" id="bitEditar"> Editar</label>
          </div>
          <div class="permiso-item">
            <label><input type="checkbox" id="bitConsulta"> Consultar</label>
          </div>
          <div class="permiso-item">
            <label><input type="checkbox" id="bitEliminar"> Eliminar</label>
          </div>
          <div class="permiso-item">
            <label><input type="checkbox" id="bitDetalle"> Ver Detalle</label>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="loading" style="display: none; text-align: center; padding: 1rem;">
    <i class="fas fa-spinner fa-spin fa-2x"></i>
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaPermisos">
      <thead>
        <tr>
          <th>ID</th>
          <th>Módulo</th>
          <th>Perfil</th>
          <th>C</th> <th>A</th> <th>E</th> <th>D</th> <th>X</th> <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="9" class="no-data">Cargando permisos...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  let currentPage = 1;
  // Obtener los permisos del usuario logueado para ESTE módulo
  const { permisos } = verificarPermisosModulo('Permisos-Perfil');

  async function cargarSelects() {
    try {
      const token = localStorage.getItem('token');
      const [modulosRes, perfilesRes] = await Promise.all([
        fetch(`${API_URL}/api/modulos-lista`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API_URL}/api/perfiles-lista`, { headers: { 'Authorization': `Bearer ${token}` } })
      ]);
      
      const modulosData = await modulosRes.json();
      const perfilesData = await perfilesRes.json();
      
      if (modulosData.success) {
        document.getElementById('idModulo').innerHTML = '<option value="">Seleccione módulo...</option>' + 
          modulosData.data.map(m => `<option value="${m.id}">${m.strnombremodulo}</option>`).join('');
      }
      
      if (perfilesData.success) {
        document.getElementById('idPerfil').innerHTML = '<option value="">Seleccione perfil...</option>' + 
          perfilesData.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
      }
    } catch (error) { console.error('Error cargando selects:', error); }
  }

  async function cargarPermisos(page = 1) {
    if (!permisos.consulta) return;
    document.getElementById('loading').style.display = 'block';
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/permisos-perfil?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) { showMsg('Error al cargar permisos', 'error'); } 
    finally { document.getElementById('loading').style.display = 'none'; }
  }

  function renderizarTabla(listaPermisos) {
    const tbody = document.getElementById('tablaBody');
    if (listaPermisos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" class="no-data">No hay permisos</td></tr>';
      return;
    }
    
    tbody.innerHTML = listaPermisos.map(p => `
      <tr>
        <td>${p.id}</td>
        <td><strong>${p.strnombremodulo}</strong></td>
        <td>${p.strnombreperfil}</td>
        <td>${p.bitconsulta ? '✅' : '❌'}</td>
        <td>${p.bitagregar ? '✅' : '❌'}</td>
        <td>${p.biteditar ? '✅' : '❌'}</td>
        <td>${p.bitdetalle ? '✅' : '❌'}</td>
        <td>${p.biteliminar ? '✅' : '❌'}</td>
        <td class="actions-cell">
          ${permisos.detalle ? `<button class="btn-icon view" onclick="verDetalle(${p.id})"><i class="fas fa-eye"></i></button>` : ''}
          ${permisos.editar ? `<button class="btn-icon edit" onclick="editarPermiso(${p.id})"><i class="fas fa-edit"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="btn-icon delete" onclick="eliminarPermiso(${p.id})"><i class="fas fa-trash"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacion(pagination) {
    const div = document.getElementById('pagination');
    if (pagination.totalPages <= 1) { div.innerHTML = ''; return; }
    
    let html = '';
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="cargarPermisos(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Nuevo Permiso';
    document.getElementById('permisoForm').reset();
    document.getElementById('permisoId').value = '';
    document.getElementById('modalPermiso').style.display = 'flex';
  };

  window.cerrarModal = () => { document.getElementById('modalPermiso').style.display = 'none'; };

  window.editarPermiso = async (id) => {
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil/${id}`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await res.json();
    if (data.success) {
      const p = data.data;
      document.getElementById('modalTitulo').textContent = 'Editar Permiso';
      document.getElementById('permisoId').value = p.id;
      document.getElementById('idModulo').value = p.idmodulo;
      document.getElementById('idPerfil').value = p.idperfil;
      document.getElementById('bitAgregar').checked = p.bitagregar;
      document.getElementById('bitEditar').checked = p.biteditar;
      document.getElementById('bitConsulta').checked = p.bitconsulta;
      document.getElementById('bitEliminar').checked = p.biteliminar;
      document.getElementById('bitDetalle').checked = p.bitdetalle;
      document.getElementById('modalPermiso').style.display = 'flex';
    }
  };

  window.guardarPermiso = async () => {
    const id = document.getElementById('permisoId').value;
    const permisoData = {
      idModulo: parseInt(document.getElementById('idModulo').value),
      idPerfil: parseInt(document.getElementById('idPerfil').value),
      bitAgregar: document.getElementById('bitAgregar').checked,
      bitEditar: document.getElementById('bitEditar').checked,
      bitConsulta: document.getElementById('bitConsulta').checked,
      bitEliminar: document.getElementById('bitEliminar').checked,
      bitDetalle: document.getElementById('bitDetalle').checked
    };
    
    const token = localStorage.getItem('token');
    const response = await fetch(id ? `${API_URL}/api/permisos-perfil/${id}` : `${API_URL}/api/permisos-perfil`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(permisoData)
    });
    
    if ((await response.json()).success) {
      showMsg(id ? 'Actualizado' : 'Creado', 'success');
      cerrarModal();
      cargarPermisos(currentPage);
    }
  };

  window.eliminarPermiso = async (id) => {
    if (!confirm('¿Eliminar permiso?')) return;
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    if ((await res.json()).success) cargarPermisos(currentPage);
  };

  function showMsg(text, type) {
    const msgDiv = document.getElementById('message');
    msgDiv.style.display = 'block';
    msgDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
    msgDiv.textContent = text;
    setTimeout(() => { msgDiv.style.display = 'none'; }, 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) document.getElementById('btnNuevoPermiso').style.display = 'block';
    cargarSelects();
    cargarPermisos();
  });
</script>

<style>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-add { background: #059669; color: white; border: none; padding: 0.7rem 1.2rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
  .modal-content { background: white; padding: 2rem; border-radius: 8px; width: 90%; max-width: 600px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group select { padding: 0.6rem; border: 1px solid #ddd; border-radius: 4px; }
  .permisos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; background: #f8fafc; padding: 1rem; border-radius: 6px; }
  .form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 1.5rem; }
  .crud-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .crud-table th, .crud-table td { padding: 0.8rem; border-bottom: 1px solid #eee; text-align: left; }
  .actions-cell { display: flex; gap: 5px; }
  .btn-icon { border: none; background: none; cursor: pointer; padding: 5px; }
  .edit { color: #f59e0b; } .delete { color: #ef4444; } .view { color: #3b82f6; }
  .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 1rem; }
  .pagination button { padding: 5px 10px; cursor: pointer; border: 1px solid #ddd; background: white; }
  .pagination button.active { background: #1e293b; color: white; border-color: #1e293b; }
  .status-message { position: fixed; bottom: 20px; right: 20px; padding: 10px 20px; border-radius: 5px; display: none; }
</style>