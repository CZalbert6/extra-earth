---
// src/pages/modulos/permisos.astro
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Matriz de Permisos | ERP" moduloActual="Permisos-Perfil">
  <div class="page-header">
    <div class="header-title">
      <h1><i class="fas fa-shield-halved"></i> Matriz de Seguridad</h1>
      <p>Configuración maestra de privilegios por perfil de usuario</p>
    </div>
    <button class="btn-add" id="btnNuevoPermiso" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-plus-circle"></i> Nueva Asignación Masiva
    </button>
  </div>

  <div class="main-card">
    <div class="table-toolbar">
      <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Filtrar por módulo o perfil...">
      </div>
    </div>

    <div class="table-responsive">
      <table class="modern-table">
        <thead>
          <tr>
            <th>Módulo</th>
            <th>Perfil</th>
            <th class="text-center">C</th>
            <th class="text-center">A</th>
            <th class="text-center">E</th>
            <th class="text-center">D</th>
            <th class="text-center">X</th>
            <th>Acción</th>
          </tr>
        </thead>
        <tbody id="tablaBody"></tbody>
      </table>
    </div>
    <div id="pagination" class="pagination-container"></div>
  </div>

  <div id="modalPermiso" class="modal-backdrop" style="display: none;">
    <div class="modal-window">
      <div class="modal-header">
        <div>
          <h3>Asignación Inteligente</h3>
          <p>Configura accesos múltiples en un solo paso</p>
        </div>
        <button class="btn-close" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="permisoForm" onsubmit="event.preventDefault(); guardarPermiso();" class="modal-body">
        <div class="selection-section">
          <label class="section-label">1. Perfil de Usuario</label>
          <div class="custom-select">
            <i class="fas fa-user-shield"></i>
            <select id="idPerfil" required onchange="validarSeleccionPerfil()">
              <option value="">Selecciona el perfil destino...</option>
            </select>
          </div>
        </div>

        <div id="contenedorMatriz" class="matriz-container disabled-section">
          <label class="section-label">2. Matriz de Módulos y Privilegios</label>
          <div class="matriz-wrapper">
            <table class="inner-matriz">
              <thead>
                <tr>
                  <th class="text-left">Módulo</th>
                  <th>Consultar</th>
                  <th>Agregar</th>
                  <th>Editar</th>
                  <th>Detalle</th>
                  <th>Eliminar</th>
                </tr>
              </thead>
              <tbody id="modulosGridBody"></tbody>
            </table>
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-ghost" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary" id="btnGuardar" disabled>
            <i class="fas fa-cloud-upload-alt"></i> <span id="textBtn">Sincronizar Permisos</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <div id="message" class="toast-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";
  const { permisos } = verificarPermisosModulo('Permisos-Perfil');

  let permisosLocales = []; 
  let permisosFiltrados = []; 
  let paginaActual = 1;
  const limitePorPagina = 5; 

  async function cargarCatalogos() {
    const token = localStorage.getItem('token');
    const [mRes, pRes] = await Promise.all([
      fetch(`${API_URL}/api/modulos-lista`, { headers: { 'Authorization': `Bearer ${token}` } }),
      fetch(`${API_URL}/api/perfiles-lista`, { headers: { 'Authorization': `Bearer ${token}` } })
    ]);
    const mData = await mRes.json();
    const pData = await pRes.json();

    if (pData.success) {
      document.getElementById('idPerfil').innerHTML = '<option value="">Selecciona el perfil destino...</option>' + 
        pData.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
    }

    if (mData.success) {
      document.getElementById('modulosGridBody').innerHTML = mData.data.map(m => `
        <tr>
          <td class="sticky-col">
            <label class="check-container">
              <input type="checkbox" class="mod-row-check" data-modid="${m.id}" onchange="toggleFilaPermisos(this)">
              <span class="custom-check"></span>
              <span class="mod-name">${m.strnombremodulo}</span>
            </label>
          </td>
          <td><input type="checkbox" class="bit-check bitConsulta" disabled></td>
          <td><input type="checkbox" class="bit-check bitAgregar" disabled></td>
          <td><input type="checkbox" class="bit-check bitEditar" disabled></td>
          <td><input type="checkbox" class="bit-check bitDetalle" disabled></td>
          <td><input type="checkbox" class="bit-check bitEliminar" disabled></td>
        </tr>
      `).join('');
    }
  }

  window.validarSeleccionPerfil = () => {
    const id = (document.getElementById('idPerfil') as HTMLSelectElement).value;
    const cont = document.getElementById('contenedorMatriz');
    const btn = document.getElementById('btnGuardar') as HTMLButtonElement;
    if (id) {
      cont.classList.remove('disabled-section');
      btn.disabled = false;
    } else {
      cont.classList.add('disabled-section');
      btn.disabled = true;
    }
  };

  window.toggleFilaPermisos = (el) => {
    const row = el.closest('tr');
    const checks = row.querySelectorAll('.bit-check');
    checks.forEach(c => {
      c.disabled = !el.checked;
      c.checked = el.checked;
    });
  };

  window.cambiarPagina = (n) => { paginaActual = n; dibujarVista(); };

  window.guardarPermiso = async () => {
    const token = localStorage.getItem('token');
    const idPerfil = (document.getElementById('idPerfil') as HTMLSelectElement).value;
    const filas = document.querySelectorAll('#modulosGridBody tr');
    const btn = document.getElementById('btnGuardar') as HTMLButtonElement;
    const txt = document.getElementById('textBtn');

    const selecciones = [];
    filas.forEach(tr => {
      const checkModulo = tr.querySelector('.mod-row-check') as HTMLInputElement;
      if (checkModulo.checked) {
        selecciones.push({
          idModulo: parseInt(checkModulo.dataset.modid),
          idPerfil: parseInt(idPerfil),
          bitConsulta: (tr.querySelector('.bitConsulta') as HTMLInputElement).checked,
          bitAgregar: (tr.querySelector('.bitAgregar') as HTMLInputElement).checked,
          bitEditar: (tr.querySelector('.bitEditar') as HTMLInputElement).checked,
          bitDetalle: (tr.querySelector('.bitDetalle') as HTMLInputElement).checked,
          bitEliminar: (tr.querySelector('.bitEliminar') as HTMLInputElement).checked
        });
      }
    });

    if (selecciones.length === 0) return alert("Debes seleccionar al menos un módulo");

    btn.disabled = true;
    txt.textContent = "Sincronizando...";

    try {
      const promesas = selecciones.map(data => 
        fetch(`${API_URL}/api/permisos-perfil`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify(data)
        })
      );
      await Promise.all(promesas);
      mostrarMensaje("Matriz de permisos actualizada", "success");
      cerrarModal();
      location.reload();
    } catch (e) {
      mostrarMensaje("Fallo en la sincronización", "error");
      btn.disabled = false;
      txt.textContent = "Sincronizar Permisos";
    }
  };

  async function cargarLista() {
    const token = localStorage.getItem('token');
    const res = await fetch(`${API_URL}/api/permisos-perfil?page=1`, { headers: { 'Authorization': `Bearer ${token}` } });
    const data = await res.json();
    if (data.success) {
      permisosLocales = data.data; 
      aplicarFiltro();
    }
  }

  function aplicarFiltro() {
    const t = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();
    permisosFiltrados = permisosLocales.filter(p => p.strnombremodulo.toLowerCase().includes(t) || p.strnombreperfil.toLowerCase().includes(t));
    paginaActual = 1;
    dibujarVista();
  }

  function dibujarVista() {
    const start = (paginaActual - 1) * limitePorPagina;
    const data = permisosFiltrados.slice(start, start + limitePorPagina);
    const tbody = document.getElementById('tablaBody');
    const ok = '<div class="badge-status ok"><i class="fas fa-check"></i></div>';
    const no = '<div class="badge-status no"><i class="fas fa-times"></i></div>';

    tbody.innerHTML = data.map(p => `
      <tr>
        <td class="mod-cell"><i class="fas fa-folder"></i> ${p.strnombremodulo}</td>
        <td><span class="profile-tag">${p.strnombreperfil}</span></td>
        <td class="text-center">${p.bitconsulta ? ok : no}</td>
        <td class="text-center">${p.bitagregar ? ok : no}</td>
        <td class="text-center">${p.biteditar ? ok : no}</td>
        <td class="text-center">${p.bitdetalle ? ok : no}</td>
        <td class="text-center">${p.biteliminar ? ok : no}</td>
        <td>
           <button class="btn-circle-delete" onclick="eliminar(${p.id})"><i class="fas fa-trash-alt"></i></button>
        </td>
      </tr>
    `).join('');
    
    renderPaginacion(Math.ceil(permisosFiltrados.length / limitePorPagina));
  }

  function renderPaginacion(total) {
    const div = document.getElementById('pagination');
    if (total <= 1) { div.innerHTML = ''; return; }
    let html = '';
    let start = Math.max(1, paginaActual - 2);
    let end = Math.min(total, start + 4);
    if (end - start < 4) start = Math.max(1, end - 4);

    if (paginaActual > 1) html += `<button class="page-link" onclick="window.cambiarPagina(${paginaActual-1})">&larr;</button>`;
    for (let i = start; i <= end; i++) {
      html += `<button class="page-link ${i === paginaActual ? 'active' : ''}" onclick="window.cambiarPagina(${i})">${i}</button>`;
    }
    if (paginaActual < total) html += `<button class="page-link" onclick="window.cambiarPagina(${paginaActual+1})">&rarr;</button>`;
    div.innerHTML = html;
  }

  window.abrirModalNuevo = () => { document.getElementById('modalPermiso').style.display = 'flex'; };
  window.cerrarModal = () => { document.getElementById('modalPermiso').style.display = 'none'; };
  window.eliminar = async (id) => {
    if(!confirm("¿Deseas revocar este acceso?")) return;
    const token = localStorage.getItem('token');
    await fetch(`${API_URL}/api/permisos-perfil/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
    location.reload();
  };

  function mostrarMensaje(m, t) {
    const el = document.getElementById('message');
    el.textContent = m; el.className = `toast-message ${t}`; el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    if(permisos.agregar) document.getElementById('btnNuevoPermiso').style.display = 'flex';
    document.getElementById('searchInput').oninput = aplicarFiltro;
    cargarCatalogos();
    cargarLista();
  });
</script>

<style is:global>
  :root {
    --primary: #4f46e5;
    --primary-hover: #4338ca;
    --bg-card: #ffffff;
    --text-dark: #1e293b;
    --text-muted: #64748b;
    --border-color: #e2e8f0;
    --success: #10b981;
    --danger: #ef4444;
  }

  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .header-title h1 { font-size: 1.75rem; color: var(--text-dark); display: flex; align-items: center; gap: 12px; margin: 0; }
  .header-title h1 i { color: var(--primary); }
  .header-title p { color: var(--text-muted); margin: 4px 0 0 0; }

  .main-card { background: var(--bg-card); border-radius: 16px; border: 1px solid var(--border-color); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); padding: 1.5rem; }
  .table-toolbar { display: flex; justify-content: flex-end; margin-bottom: 1.5rem; }
  
  .search-box { position: relative; width: 100%; max-width: 350px; }
  .search-box i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
  .search-box input { width: 100%; padding: 10px 15px 10px 40px; border-radius: 10px; border: 1.5px solid var(--border-color); outline: none; }

  .modern-table { width: 100%; border-collapse: collapse; }
  .modern-table th { text-align: left; padding: 12px 16px; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); border-bottom: 2px solid var(--border-color); }
  .modern-table td { padding: 16px; border-bottom: 1px solid #f1f5f9; color: var(--text-dark); font-size: 0.9rem; }
  .modern-table tr:hover { background: #f8fafc; }

  .mod-cell { font-weight: 700; color: var(--text-dark); }
  .mod-cell i { color: #94a3b8; margin-right: 8px; }
  
  .profile-tag { background: #eef2ff; color: #4338ca; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; border: 1px solid #c7d2fe; }

  .badge-status { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; margin: 0 auto; }
  .badge-status.ok { background: #dcfce7; color: #15803d; }
  .badge-status.no { background: #f1f5f9; color: #94a3b8; }

  .pagination-container { display: flex; justify-content: center; gap: 8px; margin-top: 1.5rem; }
  .page-link { border: 1.5px solid var(--border-color); background: white; padding: 8px 14px; border-radius: 8px; cursor: pointer; font-weight: 600; }
  .page-link.active { background: var(--primary); color: white; border-color: var(--primary); }

  .modal-backdrop { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(4px); z-index: 2000; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .modal-window { background: white; width: 100%; max-width: 850px; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); animation: zoomIn 0.3s ease; }
  
  .modal-header { padding: 20px 30px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; }
  .modal-body { padding: 30px; }
  .section-label { display: block; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }

  .custom-select { position: relative; margin-bottom: 25px; }
  .custom-select i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--primary); }
  .custom-select select { width: 100%; padding: 12px 15px 12px 45px; border-radius: 12px; border: 1.5px solid var(--border-color); appearance: none; outline: none; }

  .disabled-section { opacity: 0.4; pointer-events: none; filter: grayscale(1); }

  .matriz-wrapper { border: 1.5px solid var(--border-color); border-radius: 12px; overflow: hidden; max-height: 300px; overflow-y: auto; }
  .inner-matriz { width: 100%; border-collapse: collapse; }
  .inner-matriz th { background: #f8fafc; padding: 12px; font-size: 0.7rem; color: var(--text-muted); position: sticky; top: 0; }
  .inner-matriz td { padding: 12px; border-bottom: 1px solid #f1f5f9; text-align: center; }
  .text-left { text-align: left !important; }

  .check-container { display: flex; align-items: center; gap: 12px; cursor: pointer; }
  .check-container input { display: none; }
  .custom-check { width: 20px; height: 20px; border: 2px solid var(--border-color); border-radius: 6px; position: relative; }
  .check-container input:checked + .custom-check { background: var(--primary); border-color: var(--primary); }
  .check-container input:checked + .custom-check::after { content: '✓'; color: white; position: absolute; left: 4px; top: -1px; }

  .modal-footer { padding: 20px 30px; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; gap: 12px; }

  .btn-add { background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 600; cursor: pointer; }
  .btn-primary { background: var(--primary); color: white; border: none; padding: 12px 25px; border-radius: 10px; font-weight: 600; cursor: pointer; }
  .btn-primary:disabled { background: #94a3b8; }
  .btn-circle-delete { border: none; background: none; color: #94a3b8; font-size: 1.1rem; cursor: pointer; }
  .btn-circle-delete:hover { color: var(--danger); }

  .toast-message { position: fixed; bottom: 30px; right: 30px; padding: 15px 30px; border-radius: 12px; color: white; font-weight: 600; display: none; z-index: 3000; }
  .toast-message.success { background: var(--success); }
  .toast-message.error { background: var(--danger); }

  @keyframes zoomIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
</style>