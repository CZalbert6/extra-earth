---
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
const pageTitle = "Gestión de Permisos por Perfil";
---

<Layout title={`${pageTitle} | Sistema Corporativo`}>
  <div class="page-header">
    <h1><i class="fas fa-key"></i> {pageTitle}</h1>
    <button class="btn-add" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Permiso
    </button>
  </div>

  <!-- Modal -->
  <div id="modalPermiso" class="modal" style="display: none;">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Permiso</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="permisoForm" onsubmit="event.preventDefault(); guardarPermiso();">
        <input type="hidden" id="permisoId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Módulo *</label>
            <select id="idModulo" required>
              <option value="">Seleccione módulo...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Perfil *</label>
            <select id="idPerfil" required>
              <option value="">Seleccione perfil...</option>
            </select>
          </div>
        </div>

        <div class="permisos-grid">
          <div class="permiso-item">
            <label>
              <input type="checkbox" id="bitAgregar"> Agregar
            </label>
          </div>
          <div class="permiso-item">
            <label>
              <input type="checkbox" id="bitEditar"> Editar
            </label>
          </div>
          <div class="permiso-item">
            <label>
              <input type="checkbox" id="bitConsulta"> Consultar
            </label>
          </div>
          <div class="permiso-item">
            <label>
              <input type="checkbox" id="bitEliminar"> Eliminar
            </label>
          </div>
          <div class="permiso-item">
            <label>
              <input type="checkbox" id="bitDetalle"> Ver Detalle
            </label>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Tabla -->
  <div id="loading" style="display: none; text-align: center;">
    <i class="fas fa-spinner fa-spin"></i> Cargando...
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaPermisos">
      <thead>
        <tr>
          <th>ID</th>
          <th>Módulo</th>
          <th>Perfil</th>
          <th>Agregar</th>
          <th>Editar</th>
          <th>Consultar</th>
          <th>Eliminar</th>
          <th>Detalle</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="9" class="no-data">Cargando permisos...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script define:vars={{ API_URL }}>
  let currentPage = 1;
  let currentItem = null;
  let modulosList = [];
  let perfilesList = [];

  async function cargarSelects() {
    try {
      const token = localStorage.getItem('token');
      
      const [modulosRes, perfilesRes] = await Promise.all([
        fetch(`${API_URL}/api/modulos-lista`, { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch(`${API_URL}/api/perfiles-lista`, { headers: { 'Authorization': `Bearer ${token}` } })
      ]);
      
      const modulosData = await modulosRes.json();
      const perfilesData = await perfilesRes.json();
      
      if (modulosData.success) {
        modulosList = modulosData.data;
        document.getElementById('idModulo').innerHTML = '<option value="">Seleccione módulo...</option>' + 
          modulosData.data.map(m => `<option value="${m.id}">${m.strnombreperfil || m.strnombremodulo}</option>`).join('');
      }
      
      if (perfilesData.success) {
        perfilesList = perfilesData.data;
        document.getElementById('idPerfil').innerHTML = '<option value="">Seleccione perfil...</option>' + 
          perfilesData.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
      }
    } catch (error) {
      console.error('Error cargando selects:', error);
    }
  }

  async function cargarPermisos(page = 1) {
    document.getElementById('loading').style.display = 'block';
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/permisos-perfil?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      showMsg('Error al cargar permisos', 'error');
    } finally {
      document.getElementById('loading').style.display = 'none';
    }
  }

  function renderizarTabla(permisos) {
    const tbody = document.getElementById('tablaBody');
    
    if (permisos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" class="no-data">No hay permisos registrados</td></tr>';
      return;
    }
    
    tbody.innerHTML = permisos.map(p => `
      <tr>
        <td>${p.id}</td>
        <td>${p.strnombremodulo}</td>
        <td>${p.strnombreperfil}</td>
        <td>${p.bitagregar ? '✅' : '❌'}</td>
        <td>${p.biteditar ? '✅' : '❌'}</td>
        <td>${p.bitconsulta ? '✅' : '❌'}</td>
        <td>${p.biteliminar ? '✅' : '❌'}</td>
        <td>${p.bitdetalle ? '✅' : '❌'}</td>
        <td class="actions-cell">
          <button class="btn-icon view" onclick="verDetalle(${p.id})" title="Ver detalle">
            <i class="fas fa-eye"></i>
          </button>
          <button class="btn-icon edit" onclick="editarPermiso(${p.id})" title="Editar">
            <i class="fas fa-edit"></i>
          </button>
          <button class="btn-icon delete" onclick="eliminarPermiso(${p.id})" title="Eliminar">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacion(pagination) {
    const paginationDiv = document.getElementById('pagination');
    if (pagination.totalPages <= 1) {
      paginationDiv.innerHTML = '';
      return;
    }
    
    let html = '<div class="pagination">';
    html += `<button ${pagination.page === 1 ? 'disabled' : ''} onclick="cargarPermisos(${pagination.page - 1})">
      <i class="fas fa-chevron-left"></i>
    </button>`;
    
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="cargarPermisos(${i})">${i}</button>`;
    }
    
    html += `<button ${pagination.page === pagination.totalPages ? 'disabled' : ''} onclick="cargarPermisos(${pagination.page + 1})">
      <i class="fas fa-chevron-right"></i>
    </button>`;
    html += '</div>';
    
    paginationDiv.innerHTML = html;
  }

  window.abrirModalNuevo = () => {
    currentItem = null;
    document.getElementById('modalTitulo').textContent = 'Nuevo Permiso';
    document.getElementById('permisoForm').reset();
    document.getElementById('permisoId').value = '';
    document.getElementById('modalPermiso').style.display = 'flex';
  };

  window.cerrarModal = () => {
    document.getElementById('modalPermiso').style.display = 'none';
  };

  window.editarPermiso = async (id) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/permisos-perfil/${id}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        const permiso = data.data;
        currentItem = permiso;
        
        document.getElementById('modalTitulo').textContent = 'Editar Permiso';
        document.getElementById('permisoId').value = permiso.id;
        document.getElementById('idModulo').value = permiso.idmodulo;
        document.getElementById('idPerfil').value = permiso.idperfil;
        document.getElementById('bitAgregar').checked = permiso.bitagregar;
        document.getElementById('bitEditar').checked = permiso.biteditar;
        document.getElementById('bitConsulta').checked = permiso.bitconsulta;
        document.getElementById('bitEliminar').checked = permiso.biteliminar;
        document.getElementById('bitDetalle').checked = permiso.bitdetalle;
        
        document.getElementById('modalPermiso').style.display = 'flex';
      }
    } catch (error) {
      showMsg('Error al cargar permiso', 'error');
    }
  };

  window.verDetalle = async (id) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/permisos-perfil/${id}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        const p = data.data;
        alert(`
          ID: ${p.id}
          Módulo: ${p.strnombremodulo}
          Perfil: ${p.strnombreperfil}
          Permisos:
          - Agregar: ${p.bitagregar ? 'Sí' : 'No'}
          - Editar: ${p.biteditar ? 'Sí' : 'No'}
          - Consultar: ${p.bitconsulta ? 'Sí' : 'No'}
          - Eliminar: ${p.biteliminar ? 'Sí' : 'No'}
          - Detalle: ${p.bitdetalle ? 'Sí' : 'No'}
        `);
      }
    } catch (error) {
      showMsg('Error al cargar detalle', 'error');
    }
  };

  window.guardarPermiso = async () => {
    const permisoData = {
      idModulo: document.getElementById('idModulo').value,
      idPerfil: document.getElementById('idPerfil').value,
      bitAgregar: document.getElementById('bitAgregar').checked,
      bitEditar: document.getElementById('bitEditar').checked,
      bitConsulta: document.getElementById('bitConsulta').checked,
      bitEliminar: document.getElementById('bitEliminar').checked,
      bitDetalle: document.getElementById('bitDetalle').checked
    };
    
    const permisoId = document.getElementById('permisoId').value;
    
    if (!permisoData.idModulo || !permisoData.idPerfil) {
      showMsg('Módulo y perfil son requeridos', 'error');
      return;
    }
    
    try {
      const token = localStorage.getItem('token');
      const url = permisoId ? `${API_URL}/api/permisos-perfil/${permisoId}` : `${API_URL}/api/permisos-perfil`;
      const method = permisoId ? 'PUT' : 'POST';
      
      const response = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(permisoData)
      });
      
      const data = await response.json();
      
      if (data.success) {
        showMsg(permisoId ? 'Permiso actualizado' : 'Permiso creado', 'success');
        cerrarModal();
        cargarPermisos(currentPage);
      } else {
        showMsg(data.message, 'error');
      }
    } catch (error) {
      showMsg('Error al guardar permiso', 'error');
    }
  };

  window.eliminarPermiso = async (id) => {
    if (!confirm('¿Está seguro de eliminar este permiso?')) return;
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/permisos-perfil/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      
      if (data.success) {
        showMsg('Permiso eliminado', 'success');
        cargarPermisos(currentPage);
      } else {
        showMsg(data.message, 'error');
      }
    } catch (error) {
      showMsg('Error al eliminar permiso', 'error');
    }
  };

  function showMsg(text, type) {
    const msgDiv = document.getElementById('message');
    msgDiv.style.display = 'block';
    msgDiv.style.background = type === 'success' ? '#dcfce7' : '#fee2e2';
    msgDiv.style.color = type === 'success' ? '#166534' : '#991b1b';
    msgDiv.textContent = text;
    
    setTimeout(() => {
      msgDiv.style.display = 'none';
    }, 3000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    cargarSelects();
    cargarPermisos();
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: 1.75rem;
    color: #1e293b;
  }

  .page-header h1 i {
    margin-right: 0.5rem;
    color: #3b82f6;
  }

  .btn-add {
    background: #059669;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    font-size: 1rem;
  }

  .btn-add:hover {
    background: #047857;
  }

  .modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
  }

  .modal-content {
    background: white;
    border-radius: 8px;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal-lg {
    max-width: 700px;
  }

  .modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h3 {
    margin: 0;
    color: #1e293b;
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #64748b;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    color: #475569;
  }

  .form-group select {
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    font-size: 1rem;
    background: white;
  }

  .form-group select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .permisos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    padding: 0 1.5rem 1.5rem;
  }

  .permiso-item {
    background: #f8fafc;
    padding: 1rem;
    border-radius: 6px;
    text-align: center;
  }

  .permiso-item label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .permiso-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .form-actions {
    padding: 1.5rem;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
  }

  .btn-primary, .btn-secondary {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
  }

  .btn-primary {
    background: #1e293b;
    color: white;
  }

  .btn-primary:hover {
    background: #334155;
  }

  .btn-secondary {
    background: #f1f5f9;
    color: #475569;
  }

  .btn-secondary:hover {
    background: #e2e8f0;
  }

  .table-responsive {
    overflow-x: auto;
    background: white;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  .crud-table {
    width: 100%;
    border-collapse: collapse;
  }

  .crud-table th {
    text-align: left;
    padding: 1rem;
    background: #f8fafc;
    border-bottom: 2px solid #e2e8f0;
    color: #475569;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .crud-table td {
    padding: 1rem;
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
  }

  .crud-table tr:hover {
    background: #f8fafc;
  }

  .actions-cell {
    display: flex;
    gap: 0.5rem;
  }

  .btn-icon {
    background: none;
    border: none;
    padding: 0.5rem;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .btn-icon.view {
    color: #3b82f6;
  }
  
  .btn-icon.edit {
    color: #f59e0b;
  }
  
  .btn-icon.delete {
    color: #ef4444;
  }

  .btn-icon:hover {
    background: #f1f5f9;
    transform: scale(1.1);
  }

  .no-data {
    text-align: center;
    color: #94a3b8;
    padding: 2rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .pagination button {
    padding: 0.5rem 1rem;
    border: 1px solid #e2e8f0;
    background: white;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .pagination button:hover:not(:disabled) {
    background: #f8fafc;
    border-color: #94a3b8;
  }

  .pagination button.active {
    background: #1e293b;
    color: white;
    border-color: #1e293b;
  }

  .pagination button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status-message {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 1rem;
    border-radius: 6px;
    display: none;
    z-index: 1100;
    animation: slideInRight 0.3s ease;
  }

  @keyframes slideInRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .page-header {
      flex-direction: column;
      align-items: stretch;
    }

    .status-message {
      bottom: 1rem;
      right: 1rem;
      left: 1rem;
    }
  }
</style>