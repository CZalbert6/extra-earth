---
// src/pages/modulos/usuarios.astro
import Layout from '../../layout/layout.astro';
const API_URL = "https://extra-earth-production.up.railway.app";
---

<Layout title="Gestión de Usuarios" moduloActual="Usuario">
  <div class="page-header">
    <h1><i class="fas fa-users"></i> Gestión de Usuarios</h1>
    <button class="btn-add" id="btnNuevoUsuario" style="display: none;" onclick="abrirModalNuevo()">
      <i class="fas fa-plus"></i> Nuevo Usuario
    </button>
  </div>

  <div id="modalUsuario" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitulo">Nuevo Usuario</h3>
        <button class="close-btn" onclick="cerrarModal()">&times;</button>
      </div>
      
      <form id="usuarioForm" onsubmit="event.preventDefault(); guardarUsuario();">
        <input type="hidden" id="usuarioId">
        
        <div class="form-grid">
          <div class="form-group">
            <label>Usuario *</label>
            <input type="text" id="username" required maxlength="100">
          </div>
          
          <div class="form-group">
            <label>Nombre Completo *</label>
            <input type="text" id="nombre" required>
          </div>

          <div class="form-group">
            <label>Correo *</label>
            <input type="email" id="email" required>
          </div>
          
          <div class="form-group">
            <label>Teléfono</label>
            <input type="text" id="strNumeroCelular">
          </div>
          
          <div class="form-group">
            <label>Perfil</label>
            <select id="idPerfil">
              <option value="">Seleccione...</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Estado</label>
            <select id="idEstadoUsuario">
              <option value="1">Activo</option>
              <option value="0">Inactivo</option>
            </select>
          </div>
          
          <div class="form-group" style="grid-column: span 2;">
            <label>Contraseña</label>
            <input type="password" id="password" minlength="6">
            <small>Mínimo 6 caracteres. Dejar vacío para no cambiar en edición.</small>
          </div>
        </div>
        
        <div class="form-group imagen-group">
          <label>Foto de Perfil</label>
          <div class="imagen-preview" id="imagenPreview">
            <img id="previewImg" src="#" alt="Vista previa" style="display: none; width: 120px; height: 120px; object-fit: cover; border-radius: 50%;">
            <div class="preview-placeholder" id="previewPlaceholder">
              <i class="fas fa-user"></i>
            </div>
          </div>
          
          <div class="imagen-input" style="text-align: center;">
            <input type="file" id="imagenFile" accept="image/jpeg,image/png,image/gif" onchange="previsualizarImagen(event)">
            <button type="button" class="btn-clear" onclick="limpiarImagen()" style="display: none; background: #fee2e2; color: #ef4444; border: none; padding: 5px 10px; border-radius: 4px; cursor: margin-top: 5px;" id="btnClearImagen">
              <i class="fas fa-times"></i> Quitar imagen
            </button>
          </div>
          <input type="hidden" id="strImagenBase64">
        </div>
        
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="cerrarModal()">Cancelar</button>
          <button type="submit" class="btn-primary">Guardar Usuario</button>
        </div>
      </form>
    </div>
  </div>

  <div id="loading" style="display: none; text-align: center; padding: 2rem;">
    <i class="fas fa-spinner fa-spin fa-2x"></i><br>Cargando usuarios...
  </div>
  
  <div class="table-responsive">
    <table class="crud-table" id="tablaUsuarios">
      <thead>
        <tr>
          <th>ID</th>
          <th>Foto</th>
          <th>Usuario</th>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Perfil</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tablaBody">
        <tr>
          <td colspan="8" class="no-data">Cargando...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div id="pagination" class="pagination"></div>
  <div id="message" class="status-message"></div>
</Layout>

<script>
  import { verificarPermisosModulo } from '../../utils/permisos';
  const API_URL = "https://extra-earth-production.up.railway.app";

  let currentPage = 1;
  const { permisos } = verificarPermisosModulo('Usuario');

  window.previsualizarImagen = (event) => {
    const file = event.target.files[0];
    if (!file) return;

    if (!file.type.match('image.*')) {
      alert('Por favor, seleccione una imagen válida');
      event.target.value = '';
      return;
    }

    if (file.size > 5 * 1024 * 1024) {
      alert('La imagen es muy pesada. Máximo 5MB antes de comprimir.');
      event.target.value = '';
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.src = e.target.result;
      
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let width = img.width;
        let height = img.height;
        
        const MAX_WIDTH = 800;
        const MAX_HEIGHT = 800;
        
        if (width > height) {
          if (width > MAX_WIDTH) {
            height *= MAX_WIDTH / width;
            width = MAX_WIDTH;
          }
        } else {
          if (height > MAX_HEIGHT) {
            width *= MAX_HEIGHT / height;
            height = MAX_HEIGHT;
          }
        }
        
        canvas.width = width;
        canvas.height = height;
        
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);
        
        const compressedBase64 = canvas.toDataURL('image/jpeg', 0.7);
        document.getElementById('strImagenBase64').value = compressedBase64;
        
        const previewImg = document.getElementById('previewImg');
        previewImg.src = compressedBase64;
        previewImg.style.display = 'block';
        previewImg.style.width = '100%';
        previewImg.style.height = '100%';
        previewImg.style.objectFit = 'cover';
        
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
        
        const sizeInKB = Math.round(compressedBase64.length * 0.75 / 1024);
        console.log(`Imagen comprimida: ~${sizeInKB}KB`);
      };
    };
    
    reader.readAsDataURL(file);
  };

  window.limpiarImagen = () => {
    document.getElementById('imagenFile').value = '';
    document.getElementById('strImagenBase64').value = '';
    
    const previewImg = document.getElementById('previewImg');
    previewImg.style.display = 'none';
    previewImg.src = '#'; 
    
    document.getElementById('previewPlaceholder').style.display = 'flex';
    document.getElementById('btnClearImagen').style.display = 'none';
  };

  async function cargarPerfiles() {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/perfiles-lista`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      const select = document.getElementById('idPerfil');
      select.innerHTML = '<option value="">Seleccione...</option>' + 
        data.data.map(p => `<option value="${p.id}">${p.strnombreperfil}</option>`).join('');
    }
  }

  async function cargarUsuarios(page = 1) {
    if (!permisos.consulta) return;
    document.getElementById('loading').style.display = 'block';
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${API_URL}/api/usuarios?page=${page}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        renderizarTabla(data.data);
        renderizarPaginacion(data.pagination);
      }
    } catch (error) {
      console.error(error);
    } finally {
      document.getElementById('loading').style.display = 'none';
    }
  }

  // LA CORRECCIÓN CLAVE ESTÁ AQUÍ (Estilos en línea forzados)
  function renderizarTabla(usuarios) {
    const tbody = document.getElementById('tablaBody');
    tbody.innerHTML = usuarios.map(u => `
      <tr>
        <td style="vertical-align: middle;">${u.id}</td>
        <td style="vertical-align: middle;">
          <div style="width: 45px; height: 45px; border-radius: 50%; overflow: hidden; border: 2px solid #e2e8f0; display: flex; align-items: center; justify-content: center; background: #f8fafc; flex-shrink: 0; margin: 0;">
            <img src="${u.strimagen || 'https://ui-avatars.com/api/?name=' + u.username}" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar">
          </div>
        </td>
        <td style="vertical-align: middle;">${u.username}</td>
        <td style="vertical-align: middle;">${u.nombre}</td>
        <td style="vertical-align: middle;">${u.email}</td>
        <td style="vertical-align: middle;">${u.strnombreperfil || 'Sin perfil'}</td>
        <td style="vertical-align: middle;">
          <span class="badge ${u.idestadousuario === 1 ? 'badge-active' : 'badge-inactive'}">
            ${u.idestadousuario === 1 ? 'Activo' : 'Inactivo'}
          </span>
        </td>
        <td class="actions-cell" style="vertical-align: middle;">
          ${permisos.detalle ? `<button class="btn-icon view" onclick="verDetalle(${u.id})"><i class="fas fa-eye"></i></button>` : ''}
          ${permisos.editar ? `<button class="btn-icon edit" onclick="editarUsuario(${u.id})"><i class="fas fa-edit"></i></button>` : ''}
          ${permisos.eliminar ? `<button class="btn-icon delete" onclick="eliminarUsuario(${u.id})"><i class="fas fa-trash"></i></button>` : ''}
        </td>
      </tr>
    `).join('');
  }

  function renderizarPaginacion(pagination) {
    const div = document.getElementById('pagination');
    if (pagination.totalPages <= 1) { div.innerHTML = ''; return; }
    let html = '';
    for (let i = 1; i <= pagination.totalPages; i++) {
      html += `<button class="${i === pagination.page ? 'active' : ''}" onclick="window.cargarUsuarios(${i})">${i}</button>`;
    }
    div.innerHTML = html;
  }

  window.cargarUsuarios = cargarUsuarios;

  window.abrirModalNuevo = () => {
    document.getElementById('modalTitulo').textContent = 'Nuevo Usuario';
    document.getElementById('usuarioForm').reset();
    document.getElementById('usuarioId').value = '';
    document.getElementById('password').required = true;
    limpiarImagen();
    document.getElementById('modalUsuario').style.display = 'flex';
  };

  window.cerrarModal = () => { document.getElementById('modalUsuario').style.display = 'none'; };

  window.editarUsuario = async (id) => {
    const token = localStorage.getItem('token');
    const response = await fetch(`${API_URL}/api/usuarios/${id}`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    const data = await response.json();
    if (data.success) {
      const u = data.data;
      document.getElementById('modalTitulo').textContent = 'Editar Usuario';
      document.getElementById('usuarioId').value = u.id;
      document.getElementById('username').value = u.username;
      document.getElementById('nombre').value = u.nombre;
      document.getElementById('email').value = u.email;
      document.getElementById('strNumeroCelular').value = u.strnumerocelular || '';
      document.getElementById('idPerfil').value = u.idperfil || '';
      document.getElementById('idEstadoUsuario').value = u.idestadousuario;
      document.getElementById('password').required = false;
      
      if (u.strimagen) {
        document.getElementById('strImagenBase64').value = u.strimagen;
        const img = document.getElementById('previewImg');
        img.src = u.strimagen;
        img.style.display = 'block';
        img.style.width = '100%';
        img.style.height = '100%';
        img.style.objectFit = 'cover';
        document.getElementById('previewPlaceholder').style.display = 'none';
        document.getElementById('btnClearImagen').style.display = 'inline-block';
      } else {
        limpiarImagen();
      }
      document.getElementById('modalUsuario').style.display = 'flex';
    }
  };

  window.guardarUsuario = async () => {
    const id = document.getElementById('usuarioId').value;
    const body = {
      username: document.getElementById('username').value,
      nombre: document.getElementById('nombre').value,
      email: document.getElementById('email').value,
      password: document.getElementById('password').value,
      idPerfil: document.getElementById('idPerfil').value,
      idEstadoUsuario: document.getElementById('idEstadoUsuario').value,
      strNumeroCelular: document.getElementById('strNumeroCelular').value,
      strImagenBase64: document.getElementById('strImagenBase64').value
    };

    const token = localStorage.getItem('token');
    const response = await fetch(id ? `${API_URL}/api/usuarios/${id}` : `${API_URL}/api/usuarios`, {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
      body: JSON.stringify(body)
    });

    if ((await response.json()).success) {
      cerrarModal();
      cargarUsuarios(currentPage);
    }
  };

  window.eliminarUsuario = async (id) => {
    if (!confirm('¿Eliminar usuario?')) return;
    const token = localStorage.getItem('token');
    await fetch(`${API_URL}/api/usuarios/${id}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    cargarUsuarios(currentPage);
  };

  document.addEventListener('DOMContentLoaded', () => {
    if (permisos.agregar) document.getElementById('btnNuevoUsuario').style.display = 'block';
    cargarPerfiles();
    cargarUsuarios();
  });
</script>

<style is:global>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .btn-add { background: #059669; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; }
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
  .modal-content { background: white; padding: 2rem; border-radius: 8px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; margin-bottom: 1rem; }
  .form-group label { font-weight: 600; margin-bottom: 0.5rem; }
  .form-group input, .form-group select { padding: 0.6rem; border: 1px solid #ddd; border-radius: 4px; }
  
  .imagen-preview { 
    width: 120px; 
    height: 120px; 
    border-radius: 50%; 
    overflow: hidden; 
    background: #f1f5f9; 
    margin: 1rem auto; 
    border: 3px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-placeholder { height: 100%; width: 100%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: #94a3b8; }
  
  .crud-table { width: 100%; border-collapse: collapse; background: white; }
  .crud-table th, .crud-table td { padding: 1rem; border-bottom: 1px solid #eee; text-align: left; vertical-align: middle; }
  .badge { padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; }
  .badge-active { background: #dcfce7; color: #166534; }
  .badge-inactive { background: #fee2e2; color: #991b1b; }
  .btn-icon { border: none; background: none; cursor: pointer; padding: 5px; }
  .edit { color: #f59e0b; } .delete { color: #ef4444; } .view { color: #3b82f6; }
  .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 1rem; }
  .pagination button { padding: 5px 10px; cursor: pointer; border: 1px solid #ddd; background: white; }
  .pagination button.active { background: #1e293b; color: white; border-color: #1e293b; }
  .status-message { position: fixed; bottom: 20px; right: 20px; padding: 10px 20px; border-radius: 5px; display: none; }
</style>